@page "/system/export"
@inject AuthenticationService AuthService

<PageTitle>Export CSV</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Export CSV</h1>
        </div>

        <div class="card p-4 bg-white rounded shadow-sm">
            <p>This page provides CSV export capabilities for system data.</p>
            <button class="btn btn-primary" disabled>Export functionality coming soon</button>
        </div>
    </div>
}
