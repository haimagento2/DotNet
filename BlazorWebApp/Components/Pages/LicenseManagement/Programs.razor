@page "/programs"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Programs</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Programs</h1>
            <div class="header-actions">
                <button class="btn btn-success" @onclick="OpenAdd">+ Add Program</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="filter-bar">
            <div class="filter-group">
                <label>Search Programs</label>
                <input class="form-control" placeholder="Search by name, description or license…" @bind="filterProgramSearch" @bind:event="oninput" />
            </div>
        </div>

        @if (programs == null)
        {
            <div class="loading"><div class="spinner-border" role="status"></div><p>Loading…</p></div>
        }
        else if (programs.Count == 0)
        {
            <div class="alert alert-info">No programs found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Description</th><th>Licenses</th><th>Created</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in filteredPrograms)
                        {
                            <tr>
                                <td class="id-cell">@p.Id</td>
                                <td class="name-cell">@p.Name</td>
                                <td>@p.Description</td>
                                <td class="count-cell">@p.Licenses.Count</td>
                                <td>@p.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td><button class="btn-edit" @onclick="() => OpenEdit(p)">✏️ Edit</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats"><p><strong>Total Programs:</strong> @filteredPrograms.Count</p></div>
        }
    </div>

    @if (showForm)
    {
        <div class="modal-backdrop" @onclick="CloseForm"></div>
        <div class="modal-panel">
            <div class="modal-header">
                <h2>@(isEditing ? "Edit Program" : "Add New Program")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-row">
                        <div class="form-group">
                            <label>Program Name *</label>
                            <InputText class="form-control" @bind-Value="form.Name" placeholder="e.g. BasicCRM" />
                            <ValidationMessage For="@(() => form.Name)" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="form.Description" placeholder="Brief description…" />
                    </div>

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Add Program"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<AppProgram>? programs;
    private string filterProgramSearch = string.Empty;
    private List<AppProgram> filteredPrograms => string.IsNullOrWhiteSpace(filterProgramSearch)
        ? programs ?? new()
        : (programs ?? new()).Where(p =>
            (p.Name ?? string.Empty).Contains(filterProgramSearch, StringComparison.OrdinalIgnoreCase) ||
            (p.Description ?? string.Empty).Contains(filterProgramSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
    private bool showForm, isEditing, isSaving;
    private string? successMessage, formError;
    private ProgramForm form = new();
    private int editingId;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        // Clear change tracker to ensure fresh data from database
        DbContext.ChangeTracker.Clear();

        programs = DbContext.Programs
            .AsNoTracking() // Ensure fresh data from database
            .Include(p => p.Licenses)
            .OrderBy(p => p.Id)
            .ToList();
    }

    private async Task RefreshData() { await Load(); successMessage = null; StateHasChanged(); }

    private void OpenAdd() { form = new(); isEditing = false; formError = null; successMessage = null; showForm = true; }

    private void OpenEdit(AppProgram p)
    {
        editingId = p.Id;
        form = new ProgramForm { Name = p.Name, Description = p.Description, Price = p.Price };
        isEditing = true; formError = null; successMessage = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var e = DbContext.Programs.Find(editingId);
                if (e == null) { formError = "Program not found."; return; }
                e.Name = form.Name; e.Description = form.Description; e.Price = form.Price;
                e.UpdatedAt = DateTime.Now;
                DbContext.Programs.Update(e);
                successMessage = $"Program '{e.Name}' updated.";
            }
            else
            {
                var e = new AppProgram { Name = form.Name, Description = form.Description, Price = form.Price, CreatedAt = DateTime.Now };
                DbContext.Programs.Add(e);
                successMessage = $"Program '{e.Name}' added.";
            }
            DbContext.SaveChanges();
            await Load();
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private sealed class ProgramForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Range(0, 999999)] public decimal Price { get; set; }
    }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }
    .header-actions { display: flex; gap: .75rem; }
    .btn { border: none; padding: .65rem 1.25rem; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: .9rem; transition: opacity .2s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: #667eea; color: white; }
    .btn-success { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
    .alert { padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1.25rem; }
    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-info { background: #d1ecf1; color: #0c5460; }
    .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .alert-warning { background: #fff3cd; color: #856404; }

    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .program-card { background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,.1); padding: 1.5rem; border-top: 4px solid #667eea; }
    .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: .5rem; }
    .program-name { font-size: 1.15rem; font-weight: 700; color: #333; }
    .version-badge { background: #eef2ff; color: #667eea; padding: .2rem .6rem; border-radius: 10px; font-size: .78rem; font-weight: 600; }
    .program-desc { color: #666; font-size: .88rem; margin: .6rem 0 1rem; }
    .card-bottom { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
    .price { font-size: 1.2rem; font-weight: 700; color: #28a745; }
    .license-count { background: #667eea; color: white; padding: .2rem .65rem; border-radius: 10px; font-size: .78rem; }
    .card-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f0f0f0; padding-top: .75rem; color: #999; font-size: .8rem; }

    .table-container { background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 1.5rem; }
    .data-table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    .data-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .data-table th { padding: .9rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
    .data-table td { padding: .85rem 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .data-table tbody tr:hover { background: #f9f9f9; }
    .id-cell { font-weight: 600; color: #667eea; }
    .name-cell { font-weight: 600; color: #333; }
    .count-cell { font-weight: 700; color: #764ba2; text-align: center; }
    .price-cell { font-weight: 600; color: #28a745; }

    .filter-bar { background: white; padding: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); margin-bottom: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap; }
    .filter-group { display: flex; flex-direction: column; gap: .3rem; min-width: 280px; }
    .filter-group label { font-weight: 500; color: #555; font-size: .88rem; }
    .btn-edit { background: #fff3cd; color: #856404; border: 1px solid #ffc107; padding: .3rem .75rem; border-radius: 4px; cursor: pointer; font-size: .82rem; }
    .btn-edit:hover { background: #ffc107; color: #fff; }
    .stats { background: white; padding: 1.25rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: 0; color: #555; }
    .loading { display: flex; flex-direction: column; justify-content: center; align-items: center; min-height: 200px; background: white; border-radius: 8px; }

    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000; }
    .modal-panel { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 90%; max-width: 560px; max-height: 90vh; overflow-y: auto; background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.3); z-index: 1001; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0; color: white; }
    .modal-header h2 { margin: 0; font-size: 1.25rem; }
    .btn-close { background: rgba(255,255,255,.2); border: none; color: white; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; }
    .btn-close:hover { background: rgba(255,255,255,.35); }
    .modal-body { padding: 1.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 500; color: #444; margin-bottom: .35rem; font-size: .9rem; }
    .form-control { width: 100%; padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; box-sizing: border-box; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.15); }
    .modal-footer { display: flex; justify-content: flex-end; gap: .75rem; padding-top: 1rem; border-top: 1px solid #eee; margin-top: .5rem; }
    @@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .page-header { flex-direction: column; gap: 1rem; } }
</style>
