    private void UpdateSelectedLicensesStatus(string status)
    {
        if (licenses == null || selectedLicenseIds.Count == 0) return;

        var selected = DbContext.Licenses.Where(l => selectedLicenseIds.Contains(l.Id)).ToList();
        foreach (var license in selected)
        {
            license.Status = status;
            DbContext.Licenses.Update(license);
        }

        DbContext.SaveChanges();
        selectedLicenseIds.Clear();
        showActionsMenu = false;
        Load();
    }

