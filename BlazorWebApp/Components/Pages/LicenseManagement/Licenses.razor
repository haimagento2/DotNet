    private void Load()
    {
        // Clear change tracker to ensure fresh data from database
        DbContext.ChangeTracker.Clear();

        var query = DbContext.Licenses
            .AsNoTracking() // Ensure fresh data from database
            .Include(l => l.Program)
            .Include(l => l.Company)
            .Include(l => l.CustomerGroup)
            .Include(l => l.Owner)
                .ThenInclude(o => o!.Company)
            .Include(l => l.Owner)
                .ThenInclude(o => o!.CustomerGroup)
            .Include(l => l.Members)
            .AsQueryable();

        // Apply filters
        if (!string.IsNullOrWhiteSpace(licenseSearch))
        {
            var lowerSearch = licenseSearch.Trim().ToLower();
            query = query.Where(l => l.LicenseKey.ToLower().Contains(lowerSearch) ||
                                     l.Program!.Name!.ToLower().Contains(lowerSearch) ||
                                     (l.Owner != null && (l.Owner.FirstName.ToLower().Contains(lowerSearch) ||
                                                          l.Owner.LastName.ToLower().Contains(lowerSearch) ||
                                                          l.Owner.Email.ToLower().Contains(lowerSearch))));
        }

        if (filterProgramId > 0)
        {
            query = query.Where(l => l.ProgramId == filterProgramId);
        }
        if (filterCompanyId.HasValue)
        {
            query = query.Where(l => l.CompanyId == filterCompanyId.Value);
        }
        if (filterGroupId.HasValue)
        {
            query = query.Where(l => l.CustomerGroupId == filterGroupId.Value);
        }
        if (!string.IsNullOrWhiteSpace(filterCustomerSearch))
        {
            var lowerSearch = filterCustomerSearch.Trim().ToLower();
            query = query.Where(l => l.Owner != null && (l.Owner.FirstName.ToLower().Contains(lowerSearch) ||
                                                          l.Owner.LastName.ToLower().Contains(lowerSearch) ||
                                                          l.Owner.Email.ToLower().Contains(lowerSearch)));
        }
        if (filterType.HasValue)
        {
            query = query.Where(l => (int)l.SubLicenseType == filterType.Value);
        }
        if (!string.IsNullOrEmpty(filterStatus))
        {
            query = query.Where(l => l.Status == filterStatus);
        }

        totalRecords = query.Count();

        var orderedQuery = sortColumn switch
        {
            "Id" => sortDescending ? query.OrderByDescending(l => l.Id) : query.OrderBy(l => l.Id),
            "LicenseKey" => sortDescending ? query.OrderByDescending(l => l.LicenseKey) : query.OrderBy(l => l.LicenseKey),
            "Program" => sortDescending ? query.OrderByDescending(l => l.Program!.Name) : query.OrderBy(l => l.Program!.Name),
            "Owner" => sortDescending ? query.OrderByDescending(l => l.Owner!.FirstName).ThenByDescending(l => l.Owner!.LastName) : query.OrderBy(l => l.Owner!.FirstName).ThenBy(l => l.Owner!.LastName),
            "Company" => sortDescending ? query.OrderByDescending(l => l.Owner!.Company!.Name) : query.OrderBy(l => l.Owner!.Company!.Name),
            "CustomerGroup" => sortDescending ? query.OrderByDescending(l => l.Owner!.CustomerGroup!.Name) : query.OrderBy(l => l.Owner!.CustomerGroup!.Name),
            "Type" => sortDescending ? query.OrderByDescending(l => l.SubLicenseType) : query.OrderBy(l => l.SubLicenseType),
            "Status" => sortDescending ? query.OrderByDescending(l => l.Status) : query.OrderBy(l => l.Status),
            "Members" => sortDescending ? query.OrderByDescending(l => l.Members.Count) : query.OrderBy(l => l.Members.Count),
            "Max" => sortDescending ? query.OrderByDescending(l => l.MaxMembers) : query.OrderBy(l => l.MaxMembers),
            "StartDate" => sortDescending ? query.OrderByDescending(l => l.StartDate) : query.OrderBy(l => l.StartDate),
            "ExpiryDate" => sortDescending ? query.OrderByDescending(l => l.ExpiryDate) : query.OrderBy(l => l.ExpiryDate),
            _ => sortDescending ? query.OrderByDescending(l => l.LicenseKey) : query.OrderBy(l => l.LicenseKey),
        };

        licenses = orderedQuery
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

        // Ensure current page is valid
        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
            licenses = orderedQuery
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
        }

        programs  = DbContext.Programs.AsNoTracking().OrderBy(p => p.Name).ToList();
        companies = DbContext.Companies.AsNoTracking().OrderBy(c => c.Name).ToList();
        customerGroups = DbContext.CustomerGroups.AsNoTracking().OrderBy(g => g.Name).ToList();
        owners = DbContext.Customers.AsNoTracking().Include(c => c.Company).Include(c => c.CustomerGroup).OrderBy(c => c.Id).ToList();
    }

