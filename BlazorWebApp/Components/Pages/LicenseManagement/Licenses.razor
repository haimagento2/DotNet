    private async Task AddSelectedMembers()
    {
        if (selectedCustomerIds.Count == 0) { memberError = "Please select at least one customer."; return; }
        memberError = null;
        try
        {
                var license = DbContext.Licenses.Find(editingLicenseId);
            if (license != null && license.SubLicenseType != LicenseType.Seminar && editingMembers.Count + selectedCustomerIds.Count > license.MaxMembers)
            {
                memberError = $"This license only supports {license.MaxMembers} members.";
                return;
            }

            foreach (var cid in selectedCustomerIds)
            {
                if (!DbContext.LicenseMembers.Any(m => m.LicenseId == editingLicenseId && m.CustomerId == cid))
                    DbContext.LicenseMembers.Add(new LicenseMember { LicenseId = editingLicenseId, CustomerId = cid, OwnerId = license?.OwnerId, AssignedAt = DateTime.Today, Permission = 3 });
            }
            DbContext.SaveChanges();
            editingMembers = DbContext.LicenseMembers
                .Include(m => m.Customer).ThenInclude(c => c!.Company)
                .Where(m => m.LicenseId == editingLicenseId).ToList();
            selectedCustomerIds = new();
            Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private async Task RemoveMember(LicenseMember m)
    {
        memberError = null;
        try
        {
            var entity = DbContext.LicenseMembers.Find(m.Id);
            if (entity != null) { DbContext.LicenseMembers.Remove(entity); DbContext.SaveChanges(); }
            editingMembers = DbContext.LicenseMembers
                .Include(em => em.Customer).ThenInclude(c => c!.Company)
                .Where(em => em.LicenseId == editingLicenseId).ToList();
            Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private void UpdateMemberPermission(LicenseMember m, int permission)
    {
        m.Permission = permission;
        var entity = DbContext.LicenseMembers.Find(m.Id);
        if (entity != null)
        {
            entity.Permission = permission;
            DbContext.LicenseMembers.Update(entity);
            DbContext.SaveChanges();
        }
    }

    private int ParsePermission(object? value)
    {
        if (value != null && int.TryParse(value.ToString(), out int permission))
        {
            return permission;
        }
        return 3; // Default to Member
    }

    private async Task Save()
    {
        if (form.ProgramId == 0) { formError = "Please select a program."; return; }
        if (form.OwnerId == 0) { formError = "Please select a license owner."; return; }
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var e = DbContext.Licenses.Find(editingLicenseId);
                if (e == null) { formError = "License not found."; return; }
                e.LicenseKey = form.LicenseKey; e.ProgramId = form.ProgramId; e.CompanyId = form.CompanyId; e.CustomerGroupId = form.CustomerGroupId;
                e.OwnerId = form.OwnerId == 0 ? null : form.OwnerId;
                e.SubLicenseType = form.SubLicenseType;
                e.StartDate = form.StartDate; e.ExpiryDate = form.ExpiryDate; e.MaxMembers = form.MaxMembers; e.Status = form.Status;
                e.UpdatedAt = DateTime.Now;
                DbContext.Licenses.Update(e);
                var membersToUpdate = DbContext.LicenseMembers.Where(m => m.LicenseId == editingLicenseId).ToList();
                foreach (var member in membersToUpdate)
                {
                    member.OwnerId = e.OwnerId;
                    DbContext.LicenseMembers.Update(member);
                }
                successMessage = $"License '{e.LicenseKey}' updated.";
            }
            else
            {
                var e = new License { LicenseKey = form.LicenseKey, ProgramId = form.ProgramId, CompanyId = form.CompanyId, CustomerGroupId = form.CustomerGroupId, OwnerId = form.OwnerId == 0 ? null : form.OwnerId, SubLicenseType = form.SubLicenseType, StartDate = form.StartDate, ExpiryDate = form.ExpiryDate, MaxMembers = form.MaxMembers, Status = form.Status, CreatedAt = DateTime.Now };
                DbContext.Licenses.Add(e);
                DbContext.SaveChanges(); // Save first to get the ID

                // Automatically add the owner as a LicenseMember with Owner permission
                if (e.OwnerId.HasValue)
                {
                    var ownerMember = new LicenseMember
                    {
                        LicenseId = e.Id,
                        CustomerId = e.OwnerId.Value,
                        OwnerId = e.OwnerId.Value,
                        Permission = 1, // Owner
                        AssignedAt = DateTime.Today,
                        CreatedAt = DateTime.Now
                    };
                    DbContext.LicenseMembers.Add(ownerMember);
                    DbContext.SaveChanges();
                }

                successMessage = $"License '{e.LicenseKey}' added.";
            }
            DbContext.SaveChanges();
            Load();
            isEditing = false;
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private sealed class LicenseForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string LicenseKey { get; set; } = string.Empty;
        public int   ProgramId   { get; set; }
        public int   OwnerId     { get; set; }
        public int?  CompanyId   { get; set; }
        public int?  CustomerGroupId  { get; set; }
        public LicenseType SubLicenseType { get; set; } = LicenseType.TeamSize;
        public DateTime StartDate  { get; set; } = DateTime.Today;
        public DateTime ExpiryDate { get; set; } = DateTime.Today.AddYears(1);
        public int   MaxMembers { get; set; } = 5;
        public string Status    { get; set; } = "Active";
    }
}

