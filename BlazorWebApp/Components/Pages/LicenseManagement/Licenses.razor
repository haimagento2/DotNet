@page "/licenses"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Licenses</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Licenses</h1>
            <div class="header-actions">
                <button class="btn btn-secondary" @onclick="ToggleFilters">
                    <span>Filter</span>
                </button>
                <a class="btn btn-success" href="/licenses/add">+ Add License</a>
                <button type="button" class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
                    <div class="columns-toggle">
                        <button class="btn btn-secondary" @onclick="ToggleColumnsMenu">Columns ▾</button>
                        @if (showColumnsMenu)
                        {
                            <div class="columns-dropdown">
                                <label><input type="checkbox" @bind="showIdColumn" /> ID</label>
                                <label><input type="checkbox" @bind="showLicenseKeyColumn" /> License Key</label>
                                <label><input type="checkbox" @bind="showProgramColumn" /> Program</label>
                                <label><input type="checkbox" @bind="showOwnerColumn" /> Owner</label>
                                <label><input type="checkbox" @bind="showCompanyColumn" /> Company</label>
                                <label><input type="checkbox" @bind="showCustomerGroupColumn" /> Customer Group</label>
                                <label><input type="checkbox" @bind="showTypeColumn" /> Type</label>
                                <label><input type="checkbox" @bind="showStatusColumn" /> Status</label>
                                <label><input type="checkbox" @bind="showMembersColumn" /> Members</label>
                                <label><input type="checkbox" @bind="showMaxColumn" /> Max</label>
                                <label><input type="checkbox" @bind="showStartColumn" /> Start</label>
                                <label><input type="checkbox" @bind="showExpiryColumn" /> Expiry</label>
                                <label><input type="checkbox" @bind="showActionsColumn" /> Actions</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (showFilters)
            {
                <div class="filters-section">
                <div class="filters-row">
                    <div class="filter-group">
                        <label>Search Customer</label>
                        <div class="filter-search-wrapper">
                            <input class="form-control filter-input-search" type="text" placeholder="Search customer (name or email)…"
                                   @bind="filterCustomerSearch" @bind:event="oninput" @bind:after="ApplyLicenseFilters" />
                        </div>
                    </div>
                    <div class="filter-group">
                        <label>Program</label>
                        <select class="form-control filter-select" @bind="filterProgramId" @bind:after="ApplyLicenseFilters">
                            <option value="0">Select Option</option>
                            @foreach (var p in programs)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Company</label>
                        <select class="form-control filter-select" @bind="filterCompanyId" @bind:after="ApplyLicenseFilters">
                            <option value="">Select Option</option>
                            @foreach (var c in companies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Customer Group</label>
                        <select class="form-control filter-select" @bind="filterGroupId" @bind:after="ApplyLicenseFilters">
                            <option value="">Select Option</option>
                            @foreach (var g in customerGroups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>License Type</label>
                        <select class="form-control filter-select" @bind="filterType" @bind:after="ApplyLicenseFilters">
                            <option value="">Select Option</option>
                            <option value="1">Team size</option>
                            <option value="2">Qty purchase</option>
                            <option value="3">Seminar</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Status</label>
                        <select class="form-control filter-select" @bind="filterStatus" @bind:after="ApplyLicenseFilters">
                            <option value="">Select Option</option>
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Suspended">Suspended</option>
                            <option value="Cancel">Cancel</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>&nbsp;</label>
                        <button class="btn btn-secondary btn-filter-clear" @onclick="ClearFilters">✕ Clear</button>
                    </div>
                </div>
            </div>
            }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (licenses == null)
        {
            <div class="loading"><div class="spinner-border" role="status"></div><p>Loading…</p></div>
        }
        else if (licenses.Count == 0)
        {
            <div class="alert alert-info">No licenses found.</div>
        }
        else
        {
            <div class="table-container">
                <div class="table-toolbar">
                    <div class="records-found">@totalRecords records found</div>
                </div>
                <div class="bulk-actions">
                    <button class="btn btn-secondary" @onclick="ToggleActionsMenu">Update Status ▾</button>
                    @if (showActionsMenu)
                    {
                        <div class="actions-dropdown">
                                <button type="button" class="action-item action-item--active" @onclick="MarkSelectedAsActive">
                                    <span class="action-icon">
                                        <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='7' fill='%23155c32'/%3E%3Cpath d='M5 8l2 2 4-4' fill='none' stroke='%23fff' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" alt="Activate" />
                                    </span>
                                    <span>Activate</span>
                                </button>
                                <button type="button" class="action-item action-item--suspend" @onclick="MarkSelectedAsSuspend">
                                    <span class="action-icon">
                                        <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='7' fill='%23d39e00'/%3E%3Crect x='5' y='4' width='2' height='8' fill='%23fff'/%3E%3Crect x='9' y='4' width='2' height='8' fill='%23fff'/%3E%3C/svg%3E" alt="Suspend" />
                                    </span>
                                    <span>Suspend</span>
                                </button>
                                <button type="button" class="action-item action-item--cancel" @onclick="MarkSelectedAsCancel">
                                    <span class="action-icon">
                                        <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='7' fill='%23c82333'/%3E%3Cpath d='M5 5l6 6M11 5l-6 6' fill='none' stroke='%23fff' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E" alt="Cancel" />
                                    </span>
                                    <span>Cancel</span>
                                </button>
                                <div class="actions-divider"></div>
                                <button type="button" class="action-item action-item--clear" @onclick="ClearSelectedLicenses">
                                    <span class="action-icon">
                                        <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Cpath d='M2 4.5h12' stroke='%23444' stroke-width='1.5' stroke-linecap='round'/%3E%3Cpath d='M5 4.5v7a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-7' fill='none' stroke='%23444' stroke-width='1.5' stroke-linecap='round'/%3E%3Cpath d='M6 4.5V3.5h4v1' stroke='%23444' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E" alt="Clear" />
                                    </span>
                                    <span>Clear selection</span>
                                </button>
                            </div>
                        }
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="checkbox-column">
                                <input type="checkbox" checked="@IsAllPageSelected" @onchange="SetSelectAllPage" aria-label="Select all licenses" />
                            </th>
                            @if (showIdColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Id")'>ID <span class='sort-arrow'>@GetSortArrow("Id")</span></button></th>
                            }
                            @if (showLicenseKeyColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("LicenseKey")'>License Key <span class='sort-arrow'>@GetSortArrow("LicenseKey")</span></button></th>
                            }
                            @if (showProgramColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Program")'>Program <span class='sort-arrow'>@GetSortArrow("Program")</span></button></th>
                            }
                            @if (showOwnerColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Owner")'>Owner <span class='sort-arrow'>@GetSortArrow("Owner")</span></button></th>
                            }
                            @if (showCompanyColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Company")'>Company <span class='sort-arrow'>@GetSortArrow("Company")</span></button></th>
                            }
                            @if (showCustomerGroupColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("CustomerGroup")'>Customer Group <span class='sort-arrow'>@GetSortArrow("CustomerGroup")</span></button></th>
                            }
                            @if (showTypeColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Type")'>Type <span class='sort-arrow'>@GetSortArrow("Type")</span></button></th>
                            }
                            @if (showStatusColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Status")'>Status <span class='sort-arrow'>@GetSortArrow("Status")</span></button></th>
                            }
                            @if (showMembersColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Members")'>Members <span class='sort-arrow'>@GetSortArrow("Members")</span></button></th>
                            }
                            @if (showMaxColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("Max")'>Max <span class='sort-arrow'>@GetSortArrow("Max")</span></button></th>
                            }
                            @if (showStartColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("StartDate")'>Start Date <span class='sort-arrow'>@GetSortArrow("StartDate")</span></button></th>
                            }
                            @if (showExpiryColumn)
                            {
                                <th><button type='button' class='sort-button' @onclick='() => SetSort("ExpiryDate")'>Expiry Date <span class='sort-arrow'>@GetSortArrow("ExpiryDate")</span></button></th>
                            }
                            @if (showActionsColumn) { <th>Actions</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lic in licenses)
                        {
                            <tr>
                                <td class="checkbox-column">
                                    <input type="checkbox" checked="@selectedLicenseIds.Contains(lic.Id)" @onchange="args => ToggleLicenseSelection(lic.Id, args)" aria-label="Select license @lic.Id" />
                                </td>
                                @if (showIdColumn) { <td class="id-cell">@lic.Id</td> }
                                @if (showLicenseKeyColumn) { <td class="key-cell">@lic.LicenseKey</td> }
                                @if (showProgramColumn) { <td><span class="badge-program">@(lic.Program?.Name ?? "-")</span></td> }
                                @if (showOwnerColumn)
                                {
                                    <td>
                                        @if (lic.Owner is Customer owner)
                                        {
                                            <a href="/customers/edit/@owner.Id" class="customer-link">@owner.FirstName @owner.LastName</a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                }
                                @if (showCompanyColumn) { <td>@(lic.Owner?.Company?.Name ?? "-")</td> }
                                @if (showCustomerGroupColumn) { <td>@(lic.Owner?.CustomerGroup?.Name ?? "-")</td> }
                                @if (showTypeColumn) { <td>@lic.SubLicenseType</td> }
                                @if (showStatusColumn) { <td><span class="badge-status @lic.Status.ToLower()">@lic.Status</span></td> }
                                @if (showMembersColumn) { <td class="count-cell">@lic.Members.Count</td> }
                                @if (showMaxColumn) { <td class="count-cell">@lic.MaxMembers</td> }
                                @if (showStartColumn) { <td>@lic.StartDate.ToString("yyyy-MM-dd")</td> }
                                @if (showExpiryColumn) { <td>@lic.ExpiryDate.ToString("yyyy-MM-dd")</td> }
                                @if (showActionsColumn) { <td><button type="button" class="btn-edit" @onclick="() => OpenEdit(lic.Id)">✏️ Edit</button></td> }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats">
                <p>
                    <strong>Total Licenses:</strong> @totalRecords &nbsp;|&nbsp;
                    <strong>Active:</strong> @licenses?.Count(l => l.Status == "Active") &nbsp;|&nbsp;
                    <strong>Page @currentPage of @totalPages</strong> (@((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, totalRecords) of @totalRecords)
                </p>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    <button class="btn btn-secondary" @onclick="() => GoToPage(1)" disabled="@(!hasPreviousPage)">First</button>
                    <button class="btn btn-secondary" @onclick="PreviousPage" disabled="@(!hasPreviousPage)">Previous</button>
                    
                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        var pageNum = i;
                        <button class="btn @(pageNum == currentPage ? "btn-primary" : "btn-outline-primary")" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    }
                    
                    <button class="btn btn-secondary" @onclick="NextPage" disabled="@(!hasNextPage)">Next</button>
                    <button class="btn btn-secondary" @onclick="() => GoToPage(totalPages)" disabled="@(!hasNextPage)">Last</button>
                </div>
            }
        }
    </div>

    @if (showForm)
    {
        <div class="page-form-panel">
            <div class="panel-header">
                <h2>@(isEditing ? "Edit License" : "Add New License")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="panel-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label>License Key *</label>
                        <InputText class="form-control" @bind-Value="form.LicenseKey" placeholder="e.g. ABC123" />
                        <ValidationMessage For="@(() => form.LicenseKey)" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Program *</label>
                            <InputSelect class="form-control" @bind-Value="form.ProgramId">
                                <option value="0">— Select Program —</option>
                                @foreach (var p in programs)
                                {
                                    <option value="@p.Id">@p.Name (v@p.Version)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.ProgramId)" />
                        </div>
                        <div class="form-group">
                            <label>Company</label>
                            @if (isEditing)
                            {
                                <div class="form-control" style="padding: .6rem .85rem; background: #f5f5f5; border: 1px solid #d0d0d0; border-radius: 5px; color: #666;">
                                    @{var company = companies.FirstOrDefault(c => c.Id == form.CompanyId);}
                                    @(company?.Name ?? "— None —")
                                </div>
                            }
                            else
                            {
                                <InputSelect class="form-control" @bind-Value="form.CompanyId">
                                    <option value="">— None —</option>
                                    @foreach (var c in companies)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </InputSelect>
                            }
                        </div>
                        <div class="form-group">
                            <label>Customer Group</label>
                            @if (isEditing)
                            {
                                <div class="form-control" style="padding: .6rem .85rem; background: #f5f5f5; border: 1px solid #d0d0d0; border-radius: 5px; color: #666;">
                                    @{var group = customerGroups.FirstOrDefault(g => g.Id == form.CustomerGroupId);}
                                    @(group?.Name ?? "— None —")
                                </div>
                            }
                            else
                            {
                                <InputSelect class="form-control" @bind-Value="form.CustomerGroupId">
                                    <option value="">— None —</option>
                                    @foreach (var g in customerGroups)
                                    {
                                        <option value="@g.Id">@g.Name</option>
                                    }
                                </InputSelect>
                            }
                        </div>
                        <div class="form-group">
                            <label>License Owner</label>
                            <InputSelect class="form-control" @bind-Value="SelectedOwnerId">
                                <option value="0">— Select Owner —</option>
                                @foreach (var c in owners)
                                {
                                    <option value="@c.Id">#@c.Id — @c.FirstName @c.LastName — @c.Email — @(c.CustomerGroup?.Name ?? "No group") — @(c.Company?.Name ?? "No company")</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.OwnerId)" />
                        </div>
                        <div class="form-group">
                            <label>Sub License Type</label>
                            <InputSelect class="form-control" @bind-Value="form.SubLicenseType">
                                <option value="@((int)LicenseType.TeamSize)">Team size</option>
                                <option value="@((int)LicenseType.QtyPurchase)">Qty purchase</option>
                                <option value="@((int)LicenseType.Seminar)">Seminar</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Start Date *</label>
                            <InputDate class="form-control" @bind-Value="form.StartDate" />
                        </div>
                        <div class="form-group">
                            <label>Expiry Date *</label>
                            <InputDate class="form-control" @bind-Value="form.ExpiryDate" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Max Members</label>
                            <InputNumber class="form-control" @bind-Value="form.MaxMembers" />
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <InputSelect class="form-control" @bind-Value="form.Status">
                                <option value="Active">Active</option>
                                <option value="Expired">Expired</option>
                                <option value="Suspended">Suspended</option>
                                <option value="Cancel">Cancel</option>
                            </InputSelect>
                        </div>
                    </div>

                    @if (isEditing)
                    {
                        <hr class="section-divider" />
                        <div class="members-section">
                            <div class="members-header">
                                <span class="members-title">Assigned Customers</span>
                                <span class="members-count @(editingMembers.Count >= form.MaxMembers ? "full" : "")">
                                    @editingMembers.Count / @form.MaxMembers
                                </span>
                            </div>
                            <div class="share-summary">
                                <span>Sharing scope:</span>
                                <strong>@shareableScope</strong>
                                <span>Eligible customers:</span>
                                <strong>@shareableCustomerCount</strong>
                            </div>
                            @if (editingMembers.Count > 0)
                            {
                                <div class="members-list">
                                    @foreach (var m in editingMembers)
                                    {
                                        <div class="member-row">
                                            <div class="member-info">
                                                <span class="member-meta">ID: @m.Customer?.Id</span>
                                                <span class="member-name">@m.Customer?.FirstName @m.Customer?.LastName</span>
                                                <span class="member-company">Company: @(m.Customer?.Company?.Name ?? "—")</span>
                                                <span class="member-company">Group: @(m.Customer?.CustomerGroup?.Name ?? "—")</span>
                                            </div>
                                            <div class="member-controls">
                                                <select class="permission-select" @onchange="@((ChangeEventArgs e) => UpdateMemberPermission(m, ParsePermission(e.Value)))">
                                                    <option value="1" selected="@(m.Permission == 1)">Owner</option>
                                                    <option value="2" selected="@(m.Permission == 2)">Admin</option>
                                                    <option value="3" selected="@(m.Permission == 3)">Member</option>
                                                </select>
                                                <span class="member-date">@m.AssignedAt.ToString("yyyy-MM-dd")</span>
                                                <button type="button" class="btn-remove" @onclick="() => RemoveMember(m)" title="Remove">✕</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="no-members">No customers assigned yet.</p>
                            }
                            <div class="customer-picker">
                                <input class="form-control customer-search"
                                       placeholder="Search by name, company, city…"
                                       @bind="customerSearch" @bind:event="oninput" />
                                <div class="customer-grid">
                                    @{var avail = availableCustomers.ToList();}
                                    @if (avail.Count == 0)
                                    {
                                        <p class="no-customers">@(string.IsNullOrEmpty(customerSearch) ? "All customers already assigned." : "No customers match your search.")</p>
                                    }
                                    else
                                    {
                                        @foreach (var c in avail)
                                        {
                                            var cid = c.Id;
                                            var isSelected = selectedCustomerIds.Contains(cid);
                                            <label class="customer-item @(isSelected ? "selected" : "")">
                                                <input type="checkbox" checked="@isSelected" @onchange="() => ToggleCustomer(cid)" />
                                                <div class="customer-item-info">
                                                    <span class="customer-item-name">#@c.Id — @c.FirstName @c.LastName</span>
                                                    <span class="customer-item-sub">@(c.Company?.Name ?? "—") · @(c.CustomerGroup?.Name ?? "—")@(!string.IsNullOrEmpty(c.City) ? " · " + c.City : "")</span>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                                <div class="picker-footer">
                                    <span class="picker-count">@selectedCustomerIds.Count selected</span>
                                    <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedMembers"
                                            disabled="@(selectedCustomerIds.Count == 0 || editingMembers.Count >= form.MaxMembers)">
                                        + Add Selected (@selectedCustomerIds.Count)
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(memberError))
                            {
                                <div class="alert alert-danger" style="margin-top:.5rem;padding:.5rem .85rem;">@memberError</div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="panel-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Add License"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<License>?      licenses;
    private List<AppProgram>    programs       = new();
    private List<Company>       companies      = new();
    private List<CustomerGroup> customerGroups = new();
    private List<LicenseMember> editingMembers = new();
    private List<Customer>      allCustomers   = new();
    private List<Customer>      owners         = new();
    private bool showForm, isEditing, isSaving;
    private bool showFilters = false;
    private bool showColumnsMenu;
    private bool showIdColumn = true;
    private bool showLicenseKeyColumn = true;
    private bool showProgramColumn = true;
    private bool showOwnerColumn = true;
    private bool showCompanyColumn = true;
    private bool showCustomerGroupColumn = true;
    private bool showTypeColumn = true;
    private bool showStatusColumn = true;
    private bool showMembersColumn = true;
    private bool showMaxColumn = true;
    private bool showStartColumn = true;
    private bool showExpiryColumn = true;
    private bool showActionsColumn = true;
    private bool showActionsMenu;
    private HashSet<int> selectedLicenseIds = new();
    private string? successMessage, formError, memberError;
    private LicenseForm form = new();
    private int SelectedOwnerId
    {
        get => form.OwnerId;
        set
        {
            form.OwnerId = value;
            if (value == 0)
            {
                form.CustomerGroupId = null;
                form.CompanyId = null;
                return;
            }
            var owner = owners.FirstOrDefault(o => o.Id == value);
            form.CustomerGroupId = owner?.CustomerGroupId;
            form.CompanyId = owner?.CompanyId;
        }
