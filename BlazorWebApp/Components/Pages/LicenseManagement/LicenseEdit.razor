@page "/licenses/edit/{Id:int}"
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Edit License</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else if (license == null)
{
    <div class="alert alert-danger">License not found.</div>
}
else
{
    <div class="license-form-page">
        <div class="page-header">
            <h1>Edit License</h1>
            <button class="btn btn-secondary" @onclick="GoBack">← Back to Licenses</button>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="form-panel">
            <EditForm Model="form" OnValidSubmit="SaveLicense">
                <DataAnnotationsValidator />

                <div class="form-row">
                    <div class="form-group">
                        <label>License Key *</label>
                        <InputText class="form-control" @bind-Value="form.LicenseKey" placeholder="e.g. ABC123" />
                        <ValidationMessage For="@(() => form.LicenseKey)" />
                    </div>
                    <div class="form-group">
                        <label>Program *</label>
                        <InputSelect class="form-control" @bind-Value="form.ProgramId">
                            <option value="0">— Select Program —</option>
                            @foreach (var p in programs)
                            {
                                <option value="@p.Id">@p.Name (v@p.Version)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => form.ProgramId)" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Owner *</label>
                        <InputSelect class="form-control" @bind-Value="form.OwnerId">
                            <option value="0">— Select Owner —</option>
                            @foreach (var c in owners)
                            {
                                <option value="@c.Id">#@c.Id — @c.FirstName @c.LastName — @c.Email</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => form.OwnerId)" />
                    </div>
                    <div class="form-group">
                        <label>Company</label>
                        <InputSelect class="form-control" @bind-Value="form.CompanyId">
                            <option value="">— None —</option>
                            @foreach (var c in companies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Customer Group</label>
                        <InputSelect class="form-control" @bind-Value="form.CustomerGroupId">
                            <option value="">— None —</option>
                            @foreach (var g in customerGroups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-group">
                        <label>SubLicense Type</label>
                        <InputSelect class="form-control" @bind-Value="form.SubLicenseType">
                            <option value="@LicenseType.TeamSize">Team size</option>
                            <option value="@LicenseType.QtyPurchase">Qty purchase</option>
                            <option value="@LicenseType.Seminar">Seminar</option>
                        </InputSelect>
                        @if (form.SubLicenseType == LicenseType.Seminar)
                        {
                            <small class="form-text text-muted">Seminar licenses can be assigned to all company members regardless of Max Members.</small>
                        }
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date *</label>
                        <InputDate class="form-control" @bind-Value="form.StartDate" />
                    </div>
                    <div class="form-group">
                        <label>Expiry Date *</label>
                        <InputDate class="form-control" @bind-Value="form.ExpiryDate" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Max Members</label>
                        <InputNumber class="form-control" @bind-Value="form.MaxMembers" />
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <InputSelect class="form-control" @bind-Value="form.Status">
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Suspended">Suspended</option>
                        </InputSelect>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="alert alert-danger">@formError</div>
                }

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">@(isSaving ? "Saving…" : "Save Changes")</button>
                </div>
            </EditForm>
        </div>

        @if (license != null)
        {
            <div class="members-panel">
                <div class="panel-header">
                    <h2>Assigned Customers</h2>
                </div>
                <div class="panel-body">
                    <div class="members-section">
                        <div class="members-header">
                            <span class="members-title">License Members</span>
                            <span class="members-count @((IsUnlimitedLicense) ? "" : (form.MaxMembers > 0 && editingMembers.Count >= form.MaxMembers ? "full" : ""))">
                                @editingMembers.Count @((IsUnlimitedLicense) ? "/ All" : $"/ {form.MaxMembers}")
                            </span>
                        </div>
                        <div class="share-summary">
                            <span>Sharing scope:</span>
                            <strong>@shareableScope</strong>
                            <span>Eligible customers:</span>
                            <strong>@shareableCustomerCount</strong>
                        </div>
                        @if (editingMembers.Count > 0)
                        {
                            <div class="members-list">
                                @foreach (var m in editingMembers)
                                {
                                    <div class="member-row">
                                        <div class="member-info">
                                            <span class="member-meta">ID: @m.Customer?.Id</span>
                                            <span class="member-name">@m.Customer?.FirstName @m.Customer?.LastName</span>
                                            <span class="member-company">Company: @(m.Customer?.Company?.Name ?? "—")</span>
                                            <span class="member-company">Group: @(m.Customer?.CustomerGroup?.Name ?? "—")</span>
                                        </div>
                                        <div class="member-controls">
                                            <select class="permission-select" @onchange="@((ChangeEventArgs e) => UpdateMemberPermission(m, int.Parse(e.Value?.ToString() ?? "3")))">
                                                <option value="1" selected="@(m.Permission == 1)">Owner</option>
                                                <option value="2" selected="@(m.Permission == 2)">Admin</option>
                                                <option value="3" selected="@(m.Permission == 3)">Member</option>
                                            </select>
                                            <span class="member-date">@m.AssignedAt.ToString("yyyy-MM-dd")</span>
                                            <button type="button" class="btn-remove" @onclick="@(() => RemoveMember(m))" title="Remove">✕</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="no-members">No customers assigned yet.</p>
                        }
                        <div class="customer-picker">
                            <input class="form-control customer-search"
                                   placeholder="Search by name, company, city…"
                                   @bind="customerSearch" @bind:event="oninput" />
                            <div class="customer-grid">
                                @{var avail = availableCustomers.ToList();}
                                @if (avail.Count == 0)
                                {
                                    <p class="no-customers">@(string.IsNullOrEmpty(customerSearch) ? "All customers already assigned." : "No customers match your search.")</p>
                                }
                                else
                                {
                                    @foreach (var c in avail)
                                    {
                                        var cid = c.Id;
                                        var isSelected = selectedCustomerIds.Contains(cid);
                                        <label class="customer-item @(isSelected ? "selected" : "")">
                                            <input type="checkbox" checked="@isSelected" @onchange="() => ToggleCustomer(cid)" />
                                            <div class="customer-item-info">
                                                <span class="customer-item-name">#@c.Id — @c.FirstName @c.LastName</span>
                                                <span class="customer-item-sub">@(c.Company?.Name ?? "—") · @(c.CustomerGroup?.Name ?? "—")@(!string.IsNullOrEmpty(c.City) ? " · " + c.City : "")</span>
                                            </div>
                                        </label>
                                    }
                                }
                            </div>
                            <div class="picker-footer">
                                <span class="picker-count">@selectedCustomerIds.Count selected</span>
                                <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedMembers"
                                        disabled="@(selectedCustomerIds.Count == 0 || (!IsUnlimitedLicense && form.MaxMembers > 0 && editingMembers.Count >= form.MaxMembers))">
                                    + Add Selected (@selectedCustomerIds.Count)
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(memberError))
                        {
                            <div class="alert alert-danger" style="margin-top:.5rem;padding:.5rem .85rem;">@memberError</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private License? license;
    private LicenseForm form = new();
    private List<AppProgram> programs = new();
    private List<Company> companies = new();
    private List<CustomerGroup> customerGroups = new();
    private List<Customer> owners = new();
    private List<LicenseMember> editingMembers = new();
    private List<Customer> allCustomers = new();
    private bool isSaving;
    private string? successMessage;
    private string? formError;
    private string? memberError;
    private string customerSearch = string.Empty;
    private HashSet<int> selectedCustomerIds = new();

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        LoadData();
    }

    private IEnumerable<Customer> availableCustomers => allCustomers
        .Where(c => !editingMembers.Any(m => m.CustomerId == c.Id))
        .Where(c => string.IsNullOrEmpty(customerSearch) ||
                    $"{c.FirstName} {c.LastName}".Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    (c.Company?.Name ?? "").Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    (c.CustomerGroup?.Name ?? "").Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    c.City.Contains(customerSearch, StringComparison.OrdinalIgnoreCase));

    private int shareableCustomerCount => allCustomers.Count;
    private bool IsUnlimitedLicense => form.SubLicenseType == LicenseType.Seminar || form.MaxMembers == 0;
    private string shareableScope => form.CompanyId.HasValue
        ? $"Company: {companies.FirstOrDefault(c => c.Id == form.CompanyId)?.Name ?? "Unknown"}"
        : form.CustomerGroupId.HasValue
            ? $"Group: {customerGroups.FirstOrDefault(g => g.Id == form.CustomerGroupId)?.Name ?? "Unknown"}"
            : "None selected";

    private void GoBack() => Navigation.NavigateTo("/licenses");

    private void LoadData()
    {
        programs = DbContext.Programs.OrderBy(p => p.Name).ToList();
        companies = DbContext.Companies.OrderBy(c => c.Name).ToList();
        customerGroups = DbContext.CustomerGroups.OrderBy(g => g.Name).ToList();
        owners = DbContext.Customers.OrderBy(c => c.Id).ToList();

        license = DbContext.Licenses
            .Include(l => l.Program)
            .Include(l => l.Company)
            .Include(l => l.CustomerGroup)
            .Include(l => l.Owner)
            .FirstOrDefault(l => l.Id == Id);

        if (license != null)
        {
            form = new LicenseForm
            {
                LicenseKey = license.LicenseKey,
                ProgramId = license.ProgramId,
                CompanyId = license.CompanyId,
                CustomerGroupId = license.CustomerGroupId,
                OwnerId = license.OwnerId ?? 0,
                SubLicenseType = license.SubLicenseType,
                StartDate = license.StartDate,
                ExpiryDate = license.ExpiryDate,
                MaxMembers = license.MaxMembers,
                Status = license.Status
            };

            editingMembers = DbContext.LicenseMembers
                .Include(m => m.Customer).ThenInclude(c => c!.Company)
                .Include(m => m.Customer).ThenInclude(c => c!.CustomerGroup)
                .Where(m => m.LicenseId == license.Id).ToList();

            allCustomers = DbContext.Customers
                .Include(c => c.Company)
                .Include(c => c.CustomerGroup)
                .Where(c => (license.CompanyId.HasValue && c.CompanyId == license.CompanyId) || (license.CustomerGroupId.HasValue && c.CustomerGroupId == license.CustomerGroupId))
                .OrderBy(c => c.FirstName).ToList();
        }
    }

    private void SaveLicense()
    {
        formError = null;
        if (form.ProgramId == 0)
        {
            formError = "Please select a program.";
            return;
        }
        if (form.OwnerId == 0)
        {
            formError = "Please select a license owner.";
            return;
        }

        if (license == null)
        {
            formError = "License not found.";
            return;
        }

        try
        {
            isSaving = true;
            license.LicenseKey = form.LicenseKey;
            license.ProgramId = form.ProgramId;
            license.CompanyId = form.CompanyId;
            license.CustomerGroupId = form.CustomerGroupId;
            license.OwnerId = form.OwnerId == 0 ? null : form.OwnerId;
            license.SubLicenseType = form.SubLicenseType;
            license.StartDate = form.StartDate;
            license.ExpiryDate = form.ExpiryDate;
            license.MaxMembers = form.MaxMembers;
            license.Status = form.Status;
            license.UpdatedAt = DateTime.Now;

            DbContext.Licenses.Update(license);
            DbContext.SaveChanges();
            Navigation.NavigateTo("/licenses");
        }
        catch (Exception ex)
        {
            formError = ex.InnerException is not null
                ? $"Error: {ex.Message} - {ex.InnerException.Message}"
                : $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ToggleCustomer(int id)
    {
        if (!selectedCustomerIds.Add(id)) selectedCustomerIds.Remove(id);
    }

    private void AddSelectedMembers()
    {
        if (selectedCustomerIds.Count == 0) { memberError = "Please select at least one customer."; return; }
        memberError = null;
        try
        {
            if (license != null && license.SubLicenseType != LicenseType.Seminar && license.MaxMembers > 0 && editingMembers.Count + selectedCustomerIds.Count > license.MaxMembers)
            {
                memberError = $"This license only supports {license.MaxMembers} members.";
                return;
            }

            foreach (var cid in selectedCustomerIds)
            {
                if (!DbContext.LicenseMembers.Any(m => m.LicenseId == Id && m.CustomerId == cid))
                    DbContext.LicenseMembers.Add(new LicenseMember { LicenseId = Id, CustomerId = cid, OwnerId = license?.OwnerId, AssignedAt = DateTime.Today, Permission = 3 });
            }
            DbContext.SaveChanges();
            editingMembers = DbContext.LicenseMembers
                .Include(m => m.Customer).ThenInclude(c => c!.Company)
                .Where(m => m.LicenseId == Id).ToList();
            selectedCustomerIds = new();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private void RemoveMember(LicenseMember m)
    {
        memberError = null;
        try
        {
            var entity = DbContext.LicenseMembers.Find(m.Id);
            if (entity != null) { DbContext.LicenseMembers.Remove(entity); DbContext.SaveChanges(); }
            editingMembers = DbContext.LicenseMembers
                .Include(em => em.Customer).ThenInclude(c => c!.Company)
                .Where(em => em.LicenseId == Id).ToList();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private void UpdateMemberPermission(LicenseMember m, int permission)
    {
        m.Permission = permission;
        var entity = DbContext.LicenseMembers.Find(m.Id);
        if (entity != null)
        {
            entity.Permission = permission;
            DbContext.LicenseMembers.Update(entity);
            DbContext.SaveChanges();
        }
    }

    private int ParsePermission(object? value)
    {
        if (value != null && int.TryParse(value.ToString(), out int permission))
        {
            return permission;
        }
        return 3; // Default to Member
    }

    public sealed class LicenseForm
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string LicenseKey { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Please select a program.")]
        public int ProgramId { get; set; }

        public int OwnerId { get; set; }
        public int? CompanyId { get; set; }
        public int? CustomerGroupId { get; set; }
        public LicenseType SubLicenseType { get; set; } = LicenseType.TeamSize;
        public DateTime StartDate { get; set; } = DateTime.Today;
        public DateTime ExpiryDate { get; set; } = DateTime.Today.AddYears(1);
        public int MaxMembers { get; set; } = 5;
        public string Status { get; set; } = "Active";
    }
}

<style>
    .license-form-page { padding: 2rem; background: #f5f5f5; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1.5rem; background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .page-header h1 { margin: 0; font-size: 2rem; color: #333; }
    .form-panel { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .form-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; margin-bottom: .35rem; font-weight: 600; color: #444; }
    .form-control { width: 100%; padding: .7rem .9rem; border: 1px solid #d0d0d0; border-radius: 6px; font-size: .95rem; }
    .form-actions { display: flex; justify-content: flex-end; gap: .75rem; margin-top: 1rem; }
    .btn { border: none; padding: .65rem 1.25rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
    .btn-primary { background: #667eea; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
    .alert { padding: 1rem 1.25rem; border-radius: 8px; margin-bottom: 1rem; }
    .alert-success { background: #d4edda; color: #155724; }
    .alert-danger { background: #f8d7da; color: #721c24; }
    .members-panel { background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); margin-top: 1.5rem; }
    .panel-header { padding: 1.5rem; border-bottom: 1px solid #eee; }
    .panel-header h2 { margin: 0; font-size: 1.5rem; color: #333; }
    .panel-body { padding: 1.5rem; }
    .members-section { background: #fafafa; border: 1px solid #e8e8e8; border-radius: 8px; padding: 1rem; }
    .members-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
    .members-title { font-weight: 700; color: #333; font-size: .95rem; }
    .members-count { background: #667eea; color: white; padding: .15rem .65rem; border-radius: 10px; font-size: .8rem; font-weight: 600; }
    .members-count.full { background: #dc3545; }
    .share-summary { display: flex; gap: 1rem; margin-bottom: 1rem; font-size: .9rem; color: #666; }
    .members-list { margin-bottom: 1rem; }
    .member-row { display: flex; justify-content: space-between; align-items: center; padding: .75rem; background: white; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: .5rem; }
    .member-info { flex: 1; }
    .member-meta { font-size: .8rem; color: #666; }
    .member-name { display: block; font-weight: 600; color: #333; }
    .member-company { display: block; font-size: .85rem; color: #666; }
    .member-controls { display: flex; align-items: center; gap: .75rem; }
    .permission-select { padding: .3rem .5rem; border: 1px solid #d0d0d0; border-radius: 4px; font-size: .85rem; }
    .member-date { font-size: .8rem; color: #666; }
    .btn-remove { background: #dc3545; color: white; border: none; width: 24px; height: 24px; border-radius: 50%; cursor: pointer; font-size: .8rem; display: flex; align-items: center; justify-content: center; }
    .btn-remove:hover { background: #c82333; }
    .no-members { color: #666; font-style: italic; padding: 1rem; background: #f9f9f9; border-radius: 4px; text-align: center; }
    .customer-picker { margin-top: 1rem; }
    .customer-search { margin-bottom: 1rem; }
    .customer-grid { max-height: 300px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 6px; background: white; }
    .customer-item { display: flex; align-items: flex-start; padding: .75rem; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
    .customer-item:last-child { border-bottom: none; }
    .customer-item:hover { background: #f8f9fa; }
    .customer-item.selected { background: #e3f2fd; }
    .customer-item input[type="checkbox"] { margin-right: .75rem; margin-top: .1rem; }
    .customer-item-info { flex: 1; }
    .customer-item-name { display: block; font-weight: 600; color: #333; margin-bottom: .25rem; }
    .customer-item-sub { font-size: .85rem; color: #666; }
    .picker-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #eee; }
    .picker-count { font-size: .9rem; color: #666; }
    .btn-sm { padding: .4rem .8rem; font-size: .85rem; }
    .no-customers { color: #666; font-style: italic; padding: 1rem; text-align: center; }
</style>
