@page "/programs/edit/{id:int}"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using System.IO
@using System.Linq
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Edit Program</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else if (program == null)
{
    <div class="loading"><div class="spinner-border" role="status"></div><p>Loading program…</p></div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Edit Program: @program.Name</h1>
            <div class="header-actions">
                <button class="btn btn-secondary" @onclick="GoBack">← Back to Programs</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="form-container">
            <EditForm Model="form" OnValidSubmit="Save">
                <DataAnnotationsValidator />

                <div class="form-layout">
                    <aside class="form-sidebar">
                        <div class="sidebar-title">EDIT PROGRAM</div>
                        <button type="button" class="@GetNavLinkClass(ProgramInformationSection)" @onclick="() => SetSection(ProgramInformationSection)">Program Information</button>
                        <button type="button" class="@GetNavLinkClass(AssociatedProductsSection)" @onclick="() => SetSection(AssociatedProductsSection)">Associated Products</button>
                    </aside>

                    <div class="form-main">
                        <div class="form-footer">
                            <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @(isSaving ? "Saving…" : "Save Changes")
                            </button>
                        </div>

                        @if (activeSection == ProgramInformationSection)
                        {
                            <div class="form-section">
                                <h3>Program Information</h3>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Program Name *</label>
                                        <InputText class="form-control" @bind-Value="form.Name" placeholder="e.g. BasicCRM" />
                                        <ValidationMessage For="@(() => form.Name)" />
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Program Image Upload</label>
                                        <InputFile class="form-control" OnChange="OnImageUpload" />
                                        @if (!string.IsNullOrEmpty(form.UploadedImageName))
                                        {
                                            <small class="form-text text-muted">Uploaded: @form.UploadedImageName</small>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(form.UploadedImageName))
                                {
                                    <div class="form-group">
                                        <label>Image Preview</label>
                                        <div class="image-preview-container">
                                            <img src="@GetImagePreviewUrl()" alt="Program image preview" class="image-preview" />
                                            <button type="button" class="btn btn-danger btn-sm" @onclick="RemoveImage">Remove Image</button>
                                        </div>
                                    </div>
                                }

                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Connect to Other Portal</label>
                                        <InputSelect class="form-control" @bind-Value="form.ConnectToOtherPortal">
                                            <option value="false">No</option>
                                            <option value="true">Yes</option>
                                        </InputSelect>
                                    </div>
                                    @if (form.ConnectToOtherPortal)
                                    {
                                        <div class="form-group">
                                            <label>Portal Name</label>
                                            <InputText class="form-control" @bind-Value="form.PortalName" placeholder="Enter portal name" />
                                        </div>
                                    }
                                </div>

                                <div class="form-group">
                                    <label>Description</label>
                                    <InputTextArea class="form-control" rows="3" @bind-Value="form.Description" placeholder="Brief description…" />
                                </div>
                            </div>

                            <div class="form-section">
                                <h3>Lock Services</h3>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Padlock Display</label>
                                        <InputSelect class="form-control" @bind-Value="form.PadlockDisplay">
                                            <option value="None">None</option>
                                            <option value="DisplayAsPadlock">Display as Padlock</option>
                                            <option value="Hidden">Hidden</option>
                                        </InputSelect>
                                    </div>
                                    <div class="form-group">
                                        <label>Redirect to Locked URL Key</label>
                                        <InputSelect class="form-control" @bind-Value="form.RedirectToLockedUrlKey">
                                            <option value="false">No</option>
                                            <option value="true">Yes</option>
                                        </InputSelect>
                                    </div>
                                </div>

                                @if (form.RedirectToLockedUrlKey)
                                {
                                    <div class="form-group">
                                        <label>Locked URL Key</label>
                                        <InputText class="form-control" @bind-Value="form.LockedUrlKey" placeholder="Enter URL key" />
                                    </div>
                                }
                            </div>
                        }

                        @if (activeSection == AssociatedProductsSection)
                        {
                            <div class="form-section">
                            <div class="form-section">
                                <div class="section-header">
                                    <div>
                                        <h3>Associated Products</h3>
                                        <p class="text-muted">Select products that belong to this program.</p>
                                    </div>
                                    <button type="button" class="btn btn-primary" @onclick="OpenProductModal">+ Select Products</button>
                                </div>

                                @if (selectedProducts == null || !selectedProducts.Any())
                                {
                                    <div class="alert alert-info">No products are currently associated with this program. Click "Select Products" to add products.</div>
                                }
                                else
                                {
                                    <div class="filter-section">
                                        <div class="filter-group">
                                            <label>Search Products</label>
                                            <input type="text" class="form-control" @bind="associatedProductSearch" @bind:event="oninput" placeholder="Search by name, SKU..." />
                                        </div>
                                    </div>

                                    <div class="records-info">
                                        <span>@filteredAssociatedProducts.Count() records found</span>
                                    </div>

                                    <div class="table-container" @onclick="CloseDropdown">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Product ID</th>
                                                    <th>Product Name</th>
                                                    <th>SKU</th>
                                                    <th>Sub License Type</th>
                                                    <th>License Period</th>
                                                    <th>Subscription Linking</th>
                                                    <th>Auto-Renew License</th>
                                                    <th>Community Only</th>
                                                    <th>Send Email Instruction</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var product in filteredAssociatedProducts)
                                                {
                                                    var association = program?.ProgramProductAssociations.FirstOrDefault(pa => pa.ProductId == product.Id);
                                                    <tr>
                                                        <td>@product.Id</td>
                                                        <td>@product.Name</td>
                                                        <td>@product.SKU</td>
                                                        <td>@(association?.Type ?? "-")</td>
                                                        <td>@(association?.Period ?? "-")</td>
                                                        <td>@(association?.LinkingLicense == true ? "Yes" : association?.LinkingLicense == false ? "No" : "-")</td>
                                                        <td>No</td>
                                                        <td>@(association?.CommunityOnly == true ? "Yes" : association?.CommunityOnly == false ? "No" : "-")</td>
                                                        <td>@(product.SendEmailInstruction ? "Yes" : "No")</td>
                                                        <td>
                                                            <div class="action-dropdown" @onclick:stopPropagation="true">
                                                                <button type="button" class="btn-action-menu" @onclick="() => ToggleDropdown(product.Id)">Edit ▼</button>
                                                                @if (openDropdownProductId == product.Id)
                                                                {
                                                                    <div class="dropdown-menu" @onclick:stopPropagation="true">
                                                                        <button type="button" class="dropdown-item" @onclick="() => OpenEditProductModal(product)">Edit</button>
                                                                        <button type="button" class="dropdown-item" @onclick="() => RemoveAssociatedProduct(product.Id)">Remove</button>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(formError))
                        {
                            <div class="alert alert-danger">@formError</div>
                        }
                    </div>
                </div>
            </EditForm>

            @if (showProductModal)
            {
                <div class="modal-overlay" @onclick="CloseProductModal">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <h2>Select Associated Products (@allProducts.Count available, @selectedProductIds.Count selected)</h2>
                            <button type="button" class="close" @onclick="CloseProductModal">×</button>
                        </div>
                        <div class="modal-body">
                            <div class="form-group">
                                <label>Search Products</label>
                                <input class="form-control" @bind="productSearch" @bind:event="oninput" placeholder="Search by name, SKU, type or category..." />
                            </div>
                            <div class="table-container">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th>ID</th>
                                            <th>Name</th>
                                            <th>Category</th>
                                            <th>Type</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (allProducts != null && allProducts.Count > 0)
                                        {
                                            @foreach (var product in filteredProducts)
                                            {
                                                <tr @key="product.Id">
                                                    <td>
                                                        <input type="checkbox" checked="@selectedProductIds.Contains(product.Id)" @onchange="(e) => ToggleProductSelection(product.Id, e)" />
                                                    </td>
                                                    <td>@product.Id</td>
                                                    <td>@product.Name</td>
                                                    <td>@(product.ProductCategory?.Name ?? "-")</td>
                                                    <td>@product.Type</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" style="text-align: center; padding: 1rem;">No products available</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseProductModal">Cancel</button>
                            <button type="button" class="btn btn-primary" @onclick="ApplyProductAssociationChanges">Save Associations</button>
                        </div>
                    </div>
                </div>
            }

            @if (showEditProductModal && editingProduct != null)
            {
                <div class="modal-overlay" @onclick="CloseEditProductModal">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <h2>@editingProduct.Name</h2>
                            <button type="button" class="close" @onclick="CloseEditProductModal">×</button>
                        </div>
                        <EditForm Model="editProductForm" OnValidSubmit="SaveProductDefaults">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <div class="form-group">
                                    <label>Sub License Type *</label>
                                    <InputSelect class="form-control" @bind-Value="editProductForm.SubLicenseType">
                                        <option value="Quantity Purchased">Quantity Purchased</option>
                                        <option value="Team Size">Team Size</option>
                                        <option value="Seminar">Seminar</option>
                                    </InputSelect>
                                </div>

                                <div class="form-group">
                                    <label>License Period *</label>
                                    <InputSelect class="form-control" @bind-Value="editProductForm.LicensePeriod">
                                        <option value="">Select a license period</option>
                                        <option value="Monthly">Monthly</option>
                                        <option value="Yearly">Yearly</option>
                                        <option value="Perpetual">Perpetual</option>
                                        <option value="Custom">Custom</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => editProductForm.LicensePeriod)" />
                                </div>

                                @if (editProductForm.LicensePeriod == "Custom")
                                {
                                    <div class="form-group">
                                        <label>Custom Period (days)</label>
                                        <input type="number" class="form-control" @bind="editProductForm.CustomPeriodDays" placeholder="Enter number of days" />
                                        <small class="form-text text-muted">When License Period is Custom, specify the number of days until the license expires.</small>
                                    </div>
                                }

                                <div class="form-group">
                                    <label>Auto-Renew License</label>
                                    <InputSelect class="form-control" @bind-Value="editProductForm.AutoRenewLicense">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </InputSelect>
                                </div>

                                <div class="form-group">
                                    <label>Community Only</label>
                                    <InputSelect class="form-control" @bind-Value="editProductForm.CommunityOnly">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </InputSelect>
                                </div>

                                <div class="form-group">
                                    <label>Send Email Instruction</label>
                                    <InputSelect class="form-control" @bind-Value="editProductForm.SendEmailInstruction">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseEditProductModal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>

    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private AppProgram? program;
    private ProgramForm form = new();
    private const string ProgramInformationSection = "ProgramInformation";
    private const string AssociatedProductsSection = "AssociatedProducts";
    private bool isSaving;
    private string activeSection = ProgramInformationSection;
    private string? successMessage, formError;

    private List<Product> allProducts = new();
    private List<Product> selectedProducts = new();
    private List<int> selectedProductIds = new();
    private bool showProductModal;
    private string productSearch = string.Empty;
    private string associatedProductSearch = string.Empty;

    private int? openDropdownProductId;
    private bool showEditProductModal;
    private Product? editingProduct;
    private EditProductDefaultsForm editProductForm = new();


    private void SetSection(string section) => activeSection = section;
    private string GetNavLinkClass(string section) => activeSection == section ? "nav-link active" : "nav-link";


    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await LoadProgram();
    }

    private async Task LoadProgram()
    {
        program = await DbContext.Programs
            .Include(p => p.ProgramProductAssociations)
                .ThenInclude(pa => pa.Product)
                    .ThenInclude(p => p.ProductCategory)
            .FirstOrDefaultAsync(p => p.Id == Id);

        if (program == null) { Navigation.NavigateTo("/programs"); return; }

        await LoadProducts();

        selectedProductIds = program.ProgramProductAssociations
            .Select(pa => pa.ProductId)
            .ToList();

        selectedProducts = allProducts
            .Where(p => selectedProductIds.Contains(p.Id))
            .ToList();

        form = new ProgramForm 
        { 
            Name = program.Name, 
            Description = program.Description, 
            ConnectToOtherPortal = false, 
            PortalName = "",
            UploadedImageName = program.ProgramImage,
            PadlockDisplay = program.PadlockDisplay,
            RedirectToLockedUrlKey = program.RedirectToLockedUrlKey,
            LockedUrlKey = program.LockedUrlKey
        };
    }

    private void GoBack() => Navigation.NavigateTo("/programs");

    private async Task Save()
    {
        isSaving = true; formError = null;
        try
        {
            program!.Name = form.Name;
            program.Description = form.Description;
            program.ProgramImage = form.UploadedImageName;
            program.PadlockDisplay = form.PadlockDisplay;
            program.RedirectToLockedUrlKey = form.RedirectToLockedUrlKey;
            program.LockedUrlKey = form.LockedUrlKey;
            program.UpdatedAt = DateTime.Now;

            var existingAssociations = DbContext.ProgramProductAssociations
                .Where(pa => pa.ProgramId == program.Id)
                .ToList();

            var selectedProductIdsDistinct = selectedProductIds.Distinct().ToList();
            var associationsToRemove = existingAssociations
                .Where(pa => !selectedProductIdsDistinct.Contains(pa.ProductId))
                .ToList();

            DbContext.ProgramProductAssociations.RemoveRange(associationsToRemove);

            foreach (var productId in selectedProductIdsDistinct)
            {
                var existing = existingAssociations.FirstOrDefault(pa => pa.ProductId == productId);
                if (existing == null)
                {
                    DbContext.ProgramProductAssociations.Add(new ProgramProductAssociated
                    {
                        ProgramId = program.Id,
                        ProductId = productId,
                        Period = "Yearly"
                    });
                }
            }

            DbContext.Programs.Update(program);
            await DbContext.SaveChangesAsync();

            successMessage = $"Program '{program.Name}' updated successfully.";
            await Task.Delay(1000);
            Navigation.NavigateTo("/programs");
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private async Task LoadProducts()
    {
        allProducts = await DbContext.Products
            .Include(p => p.ProductCategory)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private void OpenProductModal()
    {
        productSearch = string.Empty;
        showProductModal = true;
        StateHasChanged();
    }

    private void CloseProductModal() => showProductModal = false;

    private IEnumerable<Product> filteredProducts => string.IsNullOrWhiteSpace(productSearch)
        ? allProducts
        : allProducts.Where(p => p.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
            || p.SKU.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
            || p.Type.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
            || (p.ProductCategory?.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<Product> filteredAssociatedProducts => string.IsNullOrWhiteSpace(associatedProductSearch)
        ? selectedProducts
        : selectedProducts.Where(p => p.Name.Contains(associatedProductSearch, StringComparison.OrdinalIgnoreCase)
            || p.SKU.Contains(associatedProductSearch, StringComparison.OrdinalIgnoreCase));

    private void ToggleProductSelection(int productId, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool value && value;

        if (isChecked)
        {
            if (!selectedProductIds.Contains(productId))
            {
                selectedProductIds.Add(productId);
            }
        }
        else
        {
            selectedProductIds.Remove(productId);
        }

        selectedProducts = allProducts.Where(p => selectedProductIds.Contains(p.Id)).ToList();
        StateHasChanged();
    }

    private void ApplyProductAssociationChanges()
    {
        selectedProducts = allProducts.Where(p => selectedProductIds.Contains(p.Id)).ToList();
        showProductModal = false;
    }

    private void RemoveAssociatedProduct(int productId)
    {
        selectedProductIds.Remove(productId);
        selectedProducts = selectedProducts.Where(p => p.Id != productId).ToList();
    }

    private void ToggleDropdown(int productId)
    {
        if (openDropdownProductId == productId)
        {
            openDropdownProductId = null;
        }
        else
        {
            openDropdownProductId = productId;
        }
        StateHasChanged();
    }

    private void CloseDropdown()
    {
        openDropdownProductId = null;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task OnImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            // Ensure the uploads directory exists
            var uploadsPath = Path.Combine("wwwroot", "uploads");
            Directory.CreateDirectory(uploadsPath);

            // Generate a unique filename
            var fileName = $"{Guid.NewGuid()}_{file.Name}";
            var filePath = Path.Combine(uploadsPath, fileName);

            // Save the file
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
            await using var fileStream = new FileStream(filePath, FileMode.Create);
            await stream.CopyToAsync(fileStream);

            form.UploadedImageName = fileName;
        }
    }

    private string GetImagePreviewUrl()
    {
        if (!string.IsNullOrEmpty(form.UploadedImageName))
        {
            return $"/uploads/{form.UploadedImageName}";
        }
        return "";
    }

    private void RemoveImage()
    {
        form.UploadedImageName = "";
    }

    private void OpenEditProductModal(Product product)
    {
        openDropdownProductId = null;
        editingProduct = product;
        var association = program?.ProgramProductAssociations.FirstOrDefault(pa => pa.ProductId == product.Id);

        editProductForm = new EditProductDefaultsForm
        {
            ProductId = product.Id,
            SubLicenseType = association?.Type ?? "Team Size",
            LicensePeriod = association?.Period ?? product.Period ?? string.Empty,
            CustomPeriodDays = association?.CustomPeriodDays ?? 0,
            EnableSubscriptionLinking = association?.LinkingLicense ?? product.EnableSubscriptionLinking,
            CommunityOnly = association?.CommunityOnly ?? product.CommunityOnly,
            SendEmailInstruction = product.SendEmailInstruction
        };

        showEditProductModal = true;
    }

    private async Task SaveProductDefaults()
    {
        if (editingProduct == null || program == null)
        {
            CloseEditProductModal();
            return;
        }

        var association = await DbContext.ProgramProductAssociations
            .FirstOrDefaultAsync(pa => pa.ProgramId == program.Id && pa.ProductId == editingProduct.Id);

        if (association != null)
        {
            association.Type = editProductForm.SubLicenseType;
            association.Period = editProductForm.LicensePeriod;
            association.CustomPeriodDays = editProductForm.CustomPeriodDays;
            association.LinkingLicense = editProductForm.EnableSubscriptionLinking;
            association.CommunityOnly = editProductForm.CommunityOnly;

            DbContext.Entry(association).State = EntityState.Modified;
        }
        else
        {
            association = new ProgramProductAssociated
            {
                ProgramId = program.Id,
                ProductId = editingProduct.Id,
                Type = editProductForm.SubLicenseType,
                Period = editProductForm.LicensePeriod,
                CustomPeriodDays = editProductForm.CustomPeriodDays,
                LinkingLicense = editProductForm.EnableSubscriptionLinking,
                CommunityOnly = editProductForm.CommunityOnly
            };

            DbContext.ProgramProductAssociations.Add(association);
            program.ProgramProductAssociations.Add(association);
        }

        await DbContext.SaveChangesAsync();
        successMessage = "Associated Product defaults saved successfully.";
        CloseEditProductModal();
        StateHasChanged();
    }

    private void CloseEditProductModal()
    {
        showEditProductModal = false;
        editingProduct = null;
    }

    private sealed class ProgramForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public bool ConnectToOtherPortal { get; set; } = false;
        public string PortalName { get; set; } = string.Empty;
        public string UploadedImageName { get; set; } = string.Empty;
        public string PadlockDisplay { get; set; } = "None";
        public bool RedirectToLockedUrlKey { get; set; } = false;
        public string LockedUrlKey { get; set; } = string.Empty;
    }

    private sealed class EditProductDefaultsForm
    {
        public int ProductId { get; set; }
        public string SubLicenseType { get; set; } = "Team Size";
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "License Period is required")]
        public string LicensePeriod { get; set; } = string.Empty;
        public int CustomPeriodDays { get; set; }
        public bool EnableSubscriptionLinking { get; set; }
        public bool AutoRenewLicense { get; set; }
        public bool CommunityOnly { get; set; }
        public bool SendEmailInstruction { get; set; }
    }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }
    .header-actions { display: flex; gap: .75rem; }
    .form-container { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .form-section { margin-bottom: 2rem; }
    .form-section h3 { margin-bottom: 1rem; color: #555; border-bottom: 1px solid #eee; padding-bottom: .5rem; }
    .form-row { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; margin-bottom: .5rem; font-weight: 500; }
    .form-control { width: 100%; padding: .75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
    .form-control:focus { outline: none; border-color: #007bff; box-shadow: 0 0 0 2px rgba(0,123,255,.25); }
