@page "/customer-groups"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Customer Groups</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning" role="alert">
        You are not authorized to access this page. Please <a href="/login">login</a> first.
    </div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Customer Groups</h1>
            <button class="btn-refresh" @onclick="RefreshData">🔄 Refresh</button>
        </div>

        @if (groups == null)
        {
            <div class="loading">
                <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
                <p>Loading groups...</p>
            </div>
        }
        else if (groups.Count == 0)
        {
            <div class="alert alert-info">No groups found.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var group in groups)
                {
                    <div class="group-card">
                        <div class="group-header">
                            <span class="group-name">@group.Name</span>
                            <span class="group-count">@group.Customers.Count customers</span>
                        </div>
                        <p class="group-description">@group.Description</p>
                        <div class="group-members">
                            @foreach (var customer in group.Customers.Take(5))
                            {
                                <span class="member-chip">@customer.FirstName @customer.LastName</span>
                            }
                            @if (group.Customers.Count > 5)
                            {
                                <span class="member-chip more">+@(group.Customers.Count - 5) more</span>
                            }
                        </div>
                        <div class="group-footer">
                            <small>Created: @group.CreatedAt.ToString("yyyy-MM-dd")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Group Name</th>
                            <th>Description</th>
                            <th>Customer Count</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in groups)
                        {
                            <tr>
                                <td class="id-cell">@group.Id</td>
                                <td><span class="badge-group">@group.Name</span></td>
                                <td>@group.Description</td>
                                <td class="count-cell">@group.Customers.Count</td>
                                <td>@group.CreatedAt.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats">
                <p><strong>Total Groups:</strong> @groups.Count &nbsp;|&nbsp; <strong>Total Customers:</strong> @groups.Sum(g => g.Customers.Count)</p>
            </div>
        }
    </div>
}

@code {
    private List<CustomerGroup>? groups;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        try
        {
            groups = DbContext.CustomerGroups
                .Include(g => g.Customers)
                .OrderBy(g => g.Id)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            groups = new();
        }
    }

    private async Task RefreshData() { await Load(); StateHasChanged(); }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }

    .page-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 2rem; background: white; padding: 1.5rem;
        border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }

    .btn-refresh {
        background: #764ba2; color: white; border: none;
        padding: .75rem 1.5rem; border-radius: 4px; cursor: pointer;
        font-weight: 500; transition: background .3s;
    }
    .btn-refresh:hover { background: #5e3a82; }

    .cards-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem; margin-bottom: 2rem;
    }

    .group-card {
        background: white; border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.1); padding: 1.5rem;
        border-top: 4px solid #764ba2;
    }

    .group-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
    .group-name { font-size: 1.25rem; font-weight: 700; color: #333; }
    .group-count {
        background: #764ba2; color: white;
        padding: .2rem .7rem; border-radius: 12px; font-size: .8rem; font-weight: 600;
    }

    .group-description { color: #666; font-size: .9rem; margin-bottom: 1rem; }

    .group-members { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1rem; }
    .member-chip {
        background: #f0ebf8; color: #764ba2;
        padding: .15rem .6rem; border-radius: 10px; font-size: .78rem;
    }
    .member-chip.more { background: #e0e0e0; color: #666; }

    .group-footer { color: #999; font-size: .8rem; border-top: 1px solid #f0f0f0; padding-top: .75rem; }

    .table-container {
        background: white; border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 2rem;
    }

    .data-table { width: 100%; border-collapse: collapse; font-size: .95rem; }
    .data-table thead { background: linear-gradient(135deg, #764ba2 0%, #667eea 100%); color: white; }
    .data-table th { padding: 1rem; text-align: left; font-weight: 600; }
    .data-table td { padding: 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .data-table tbody tr:hover { background: #f9f9f9; }

    .id-cell { font-weight: 600; color: #764ba2; }
    .count-cell { font-weight: 700; color: #764ba2; text-align: center; }

    .badge-group {
        background: linear-gradient(135deg, #764ba2, #667eea);
        color: white; padding: .25rem .75rem; border-radius: 12px; font-size: .85rem; font-weight: 600;
    }

    .loading {
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        min-height: 200px; background: white; border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }

    .stats { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: .5rem 0; color: #555; }
</style>
