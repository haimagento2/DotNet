@page "/companies"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Companies</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning" role="alert">
        You are not authorized to access this page. Please <a href="/login">login</a> first.
    </div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Companies</h1>
            <button class="btn-refresh" @onclick="RefreshData">🔄 Refresh</button>
        </div>

        @if (companies == null)
        {
            <div class="loading">
                <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
                <p>Loading companies...</p>
            </div>
        }
        else if (companies.Count == 0)
        {
            <div class="alert alert-info">No companies found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Industry</th>
                            <th>City</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Website</th>
                            <th>Customers</th>
                            <th>Since</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var company in companies)
                        {
                            <tr>
                                <td class="id-cell">@company.Id</td>
                                <td class="name-cell">@company.Name</td>
                                <td><span class="badge-industry">@company.Industry</span></td>
                                <td>@company.City</td>
                                <td><a href="tel:@company.Phone">@company.Phone</a></td>
                                <td><a href="mailto:@company.Email">@company.Email</a></td>
                                <td><a href="https://@company.Website" target="_blank">@company.Website</a></td>
                                <td class="count-cell">@company.Customers.Count</td>
                                <td>@company.CreatedAt.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats">
                <p><strong>Total Companies:</strong> @companies.Count</p>
            </div>
        }
    </div>
}

@code {
    private List<Company>? companies;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        try
        {
            companies = DbContext.Companies
                .Include(c => c.Customers)
                .OrderBy(c => c.Id)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            companies = new();
        }
    }

    private async Task RefreshData() { await Load(); StateHasChanged(); }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }

    .page-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 2rem; background: white; padding: 1.5rem;
        border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }

    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }

    .btn-refresh {
        background: #667eea; color: white; border: none;
        padding: .75rem 1.5rem; border-radius: 4px; cursor: pointer;
        font-weight: 500; transition: background .3s;
    }
    .btn-refresh:hover { background: #5568d3; }

    .table-container {
        background: white; border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 2rem;
    }

    .data-table { width: 100%; border-collapse: collapse; font-size: .9rem; }

    .data-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .data-table th { padding: 1rem; text-align: left; font-weight: 600; }
    .data-table td { padding: .9rem 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .data-table tbody tr:hover { background: #f9f9f9; }
    .data-table a { color: #667eea; text-decoration: none; }
    .data-table a:hover { text-decoration: underline; }

    .id-cell { font-weight: 600; color: #667eea; }
    .name-cell { font-weight: 600; color: #333; }
    .count-cell { font-weight: 700; color: #764ba2; text-align: center; }

    .badge-industry {
        background: #eef2ff; color: #667eea;
        padding: .2rem .7rem; border-radius: 12px; font-size: .8rem; font-weight: 500;
    }

    .loading {
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        min-height: 200px; background: white; border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }

    .stats { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: .5rem 0; color: #555; }
</style>
