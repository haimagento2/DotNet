@page "/license-members"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>License Members</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>License Members</h1>
            <div class="header-actions">
                <button class="btn btn-success" @onclick="OpenAdd">+ Assign Member</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <!-- Filter bar -->
        <div class="filter-bar">
            <div class="filter-group">
                <label>Filter by License</label>
                <select class="form-control" @onchange="FilterChanged">
                    <option value="0">All Licenses</option>
                    @foreach (var lic in allLicenses)
                    {
                        <option value="@lic.Id">@lic.LicenseKey (@(lic.Program?.Name ?? "-"))</option>
                    }
                </select>
            </div>
        </div>

        @if (members == null)
        {
            <div class="loading"><div class="spinner-border" role="status"></div><p>Loading…</p></div>
        }
        else if (filtered.Count == 0)
        {
            <div class="alert alert-info">No members found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr><th>ID</th><th>License Key</th><th>Program</th><th>Customer</th><th>Company</th><th>Assigned</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in filtered)
                        {
                            <tr>
                                <td class="id-cell">@m.Id</td>
                                <td class="key-cell">@(m.License?.LicenseKey ?? "-")</td>
                                <td><span class="badge-program">@(m.License?.Program?.Name ?? "-")</span></td>
                                <td class="name-cell">@(m.Customer?.FirstName) @(m.Customer?.LastName)</td>
                                <td>@(m.Customer?.Company?.Name ?? "-")</td>
                                <td>@m.AssignedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <button class="btn-edit" @onclick="() => OpenEdit(m)">✏️ Edit</button>
                                    <button class="btn-delete" @onclick="() => Remove(m)">🗑 Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats"><p><strong>Showing:</strong> @filtered.Count of @members.Count total assignments</p></div>
        }
    </div>

    @if (showForm)
    {
        <div class="modal-backdrop" @onclick="CloseForm"></div>
        <div class="modal-panel">
            <div class="modal-header">
                <h2>@(isEditing ? "Edit Assignment" : "Assign Member to License")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label>License *</label>
                        <InputSelect class="form-control" @bind-Value="form.LicenseId">
                            <option value="0">— Select License —</option>
                            @foreach (var lic in allLicenses)
                            {
                                <option value="@lic.Id">@lic.LicenseKey — @(lic.Program?.Name) (@(lic.Company?.Name ?? "No company"))</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label>Customer *</label>
                        <InputSelect class="form-control" @bind-Value="form.CustomerId">
                            <option value="0">— Select Customer —</option>
                            @foreach (var c in allCustomers)
                            {
                                <option value="@c.Id">@c.FirstName @c.LastName (@(c.Company?.Name ?? "No company"))</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label>Assigned Date</label>
                        <InputDate class="form-control" @bind-Value="form.AssignedAt" />
                    </div>

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Assign"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<LicenseMember>? members;
    private List<License>        allLicenses  = new();
    private List<Customer>       allCustomers = new();
    private int filterLicenseId;
    private List<LicenseMember> filtered => filterLicenseId == 0
        ? (members ?? new())
        : (members ?? new()).Where(m => m.LicenseId == filterLicenseId).ToList();

    private bool showForm, isEditing, isSaving;
    private string? successMessage, formError;
    private MemberForm form = new();
    private int editingId;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        members = DbContext.LicenseMembers
            .Include(m => m.License).ThenInclude(l => l!.Program)
            .Include(m => m.License).ThenInclude(l => l!.Company)
            .Include(m => m.Customer).ThenInclude(c => c!.Company)
            .OrderBy(m => m.LicenseId).ThenBy(m => m.Id)
            .ToList();

        allLicenses  = DbContext.Licenses.Include(l => l.Program).Include(l => l.Company).OrderBy(l => l.LicenseKey).ToList();
        allCustomers = DbContext.Customers.Include(c => c.Company).OrderBy(c => c.FirstName).ToList();
    }

    private async Task RefreshData() { await Load(); successMessage = null; StateHasChanged(); }

    private void FilterChanged(ChangeEventArgs e)
    {
        filterLicenseId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        StateHasChanged();
    }

    private void OpenAdd()
    {
        form = new MemberForm { AssignedAt = DateTime.Today };
        isEditing = false; formError = null; successMessage = null; showForm = true;
    }

    private void OpenEdit(LicenseMember m)
    {
        editingId = m.Id;
        form = new MemberForm { LicenseId = m.LicenseId, CustomerId = m.CustomerId, AssignedAt = m.AssignedAt };
        isEditing = true; formError = null; successMessage = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        if (form.LicenseId == 0)  { formError = "Please select a license.";  return; }
        if (form.CustomerId == 0) { formError = "Please select a customer."; return; }
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var e = DbContext.LicenseMembers.Find(editingId);
                if (e == null) { formError = "Record not found."; return; }
                e.LicenseId = form.LicenseId; e.CustomerId = form.CustomerId; e.AssignedAt = form.AssignedAt;
                DbContext.LicenseMembers.Update(e);
                successMessage = "Assignment updated.";
            }
            else
            {
                var exists = DbContext.LicenseMembers.Any(m => m.LicenseId == form.LicenseId && m.CustomerId == form.CustomerId);
                if (exists) { formError = "This customer is already assigned to that license."; return; }
                DbContext.LicenseMembers.Add(new LicenseMember { LicenseId = form.LicenseId, CustomerId = form.CustomerId, AssignedAt = form.AssignedAt });
                successMessage = "Member assigned successfully.";
            }
            DbContext.SaveChanges();
            await Load();
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private async Task Remove(LicenseMember m)
    {
        try
        {
            DbContext.LicenseMembers.Remove(m);
            DbContext.SaveChanges();
            successMessage = "Member removed from license.";
            await Load();
            StateHasChanged();
        }
        catch (Exception ex) { successMessage = null; Console.WriteLine(ex.Message); }
    }

    private sealed class MemberForm
    {
        public int      LicenseId  { get; set; }
        public int      CustomerId { get; set; }
        public DateTime AssignedAt { get; set; } = DateTime.Today;
    }
}

<style>
