@page "/licenses"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Licenses</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Licenses</h1>
            <div class="header-actions">
                <button class="btn btn-success" @onclick="OpenAdd">+ Add License</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (licenses == null)
        {
            <div class="loading"><div class="spinner-border" role="status"></div><p>Loading…</p></div>
        }
        else if (licenses.Count == 0)
        {
            <div class="alert alert-info">No licenses found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th><th>License Key</th><th>Program</th><th>Company</th>
                            <th>Status</th><th>Members</th><th>Max</th><th>Start</th><th>Expiry</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lic in licenses)
                        {
                            <tr>
                                <td class="id-cell">@lic.Id</td>
                                <td class="key-cell">@lic.LicenseKey</td>
                                <td><span class="badge-program">@(lic.Program?.Name ?? "-")</span></td>
                                <td>@(lic.Company?.Name ?? "-")</td>
                                <td><span class="badge-status @lic.Status.ToLower()">@lic.Status</span></td>
                                <td class="count-cell">@lic.Members.Count</td>
                                <td class="count-cell">@lic.MaxMembers</td>
                                <td>@lic.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@lic.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                <td><button class="btn-edit" @onclick="() => OpenEdit(lic)">✏️ Edit</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats"><p><strong>Total Licenses:</strong> @licenses.Count &nbsp;|&nbsp; <strong>Active:</strong> @licenses.Count(l => l.Status == "Active")</p></div>
        }
    </div>

    @if (showForm)
    {
        <div class="modal-backdrop" @onclick="CloseForm"></div>
        <div class="modal-panel">
            <div class="modal-header">
                <h2>@(isEditing ? "Edit License" : "Add New License")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label>License Key *</label>
                        <InputText class="form-control" @bind-Value="form.LicenseKey" placeholder="e.g. LIC-2025-PRO-001" />
                        <ValidationMessage For="@(() => form.LicenseKey)" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Program *</label>
                            <InputSelect class="form-control" @bind-Value="form.ProgramId">
                                <option value="0">— Select Program —</option>
                                @foreach (var p in programs)
                                {
                                    <option value="@p.Id">@p.Name (v@p.Version)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.ProgramId)" />
                        </div>
                        <div class="form-group">
                            <label>Company</label>
                            <InputSelect class="form-control" @bind-Value="form.CompanyId">
                                <option value="">— None —</option>
                                @foreach (var c in companies)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Start Date *</label>
                            <InputDate class="form-control" @bind-Value="form.StartDate" />
                        </div>
                        <div class="form-group">
                            <label>Expiry Date *</label>
                            <InputDate class="form-control" @bind-Value="form.ExpiryDate" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Max Members</label>
                            <InputNumber class="form-control" @bind-Value="form.MaxMembers" />
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <InputSelect class="form-control" @bind-Value="form.Status">
                                <option value="Active">Active</option>
                                <option value="Expired">Expired</option>
                                <option value="Suspended">Suspended</option>
                            </InputSelect>
                        </div>
                    </div>

                    @if (isEditing)
                    {
                        <hr class="section-divider" />
                        <div class="members-section">
                            <div class="members-header">
                                <span class="members-title">Assigned Customers</span>
                                <span class="members-count @(editingMembers.Count >= form.MaxMembers ? "full" : "")">
                                    @editingMembers.Count / @form.MaxMembers
                                </span>
                            </div>
                            @if (editingMembers.Count > 0)
                            {
                                <div class="members-list">
                                    @foreach (var m in editingMembers)
                                    {
                                        <div class="member-row">
                                            <div class="member-info">
                                                <span class="member-name">@m.Customer?.FirstName @m.Customer?.LastName</span>
                                                <span class="member-company">@(m.Customer?.Company?.Name ?? "—")</span>
                                            </div>
                                            <div class="member-meta">
                                                <span class="member-date">@m.AssignedAt.ToString("yyyy-MM-dd")</span>
                                                <button type="button" class="btn-remove" @onclick="() => RemoveMember(m)" title="Remove">✕</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="no-members">No customers assigned yet.</p>
                            }
                            <div class="customer-picker">
                                <input class="form-control customer-search"
                                       placeholder="Search by name, company, city…"
                                       @bind="customerSearch" @bind:event="oninput" />
                                <div class="customer-grid">
                                    @{var avail = availableCustomers.ToList();}
                                    @if (avail.Count == 0)
                                    {
                                        <p class="no-customers">@(string.IsNullOrEmpty(customerSearch) ? "All customers already assigned." : "No customers match your search.")</p>
                                    }
                                    else
                                    {
                                        @foreach (var c in avail)
                                        {
                                            var cid = c.Id;
                                            var isSelected = selectedCustomerIds.Contains(cid);
                                            <label class="customer-item @(isSelected ? "selected" : "")">
                                                <input type="checkbox" checked="@isSelected" @onchange="() => ToggleCustomer(cid)" />
                                                <div class="customer-item-info">
                                                    <span class="customer-item-name">@c.FirstName @c.LastName</span>
                                                    <span class="customer-item-sub">@(c.Company?.Name ?? "—")@(!string.IsNullOrEmpty(c.City) ? " · " + c.City : "")</span>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                                <div class="picker-footer">
                                    <span class="picker-count">@selectedCustomerIds.Count selected</span>
                                    <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedMembers"
                                            disabled="@(selectedCustomerIds.Count == 0 || editingMembers.Count >= form.MaxMembers)">
                                        + Add Selected (@selectedCustomerIds.Count)
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(memberError))
                            {
                                <div class="alert alert-danger" style="margin-top:.5rem;padding:.5rem .85rem;">@memberError</div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Add License"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<License>?      licenses;
    private List<AppProgram>    programs       = new();
    private List<Company>       companies      = new();
    private List<LicenseMember> editingMembers = new();
    private List<Customer>      allCustomers   = new();
    private bool showForm, isEditing, isSaving;
    private string? successMessage, formError, memberError;
    private LicenseForm form = new();
    private int editingId;
    private string customerSearch = string.Empty;
    private HashSet<int> selectedCustomerIds = new();

    private IEnumerable<Customer> availableCustomers => allCustomers
        .Where(c => !editingMembers.Any(m => m.CustomerId == c.Id))
        .Where(c => string.IsNullOrEmpty(customerSearch) ||
                    $"{c.FirstName} {c.LastName}".Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    (c.Company?.Name ?? "").Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    c.City.Contains(customerSearch, StringComparison.OrdinalIgnoreCase));

    private void ToggleCustomer(int id)
    {
        if (!selectedCustomerIds.Add(id)) selectedCustomerIds.Remove(id);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        licenses  = DbContext.Licenses.Include(l => l.Program).Include(l => l.Company).Include(l => l.Members).OrderBy(l => l.Id).ToList();
        programs  = DbContext.Programs.OrderBy(p => p.Name).ToList();
        companies = DbContext.Companies.OrderBy(c => c.Name).ToList();
    }

    private async Task RefreshData() { await Load(); successMessage = null; StateHasChanged(); }

    private void OpenAdd()
    {
        form = new LicenseForm { StartDate = DateTime.Today, ExpiryDate = DateTime.Today.AddYears(1) };
        isEditing = false; formError = null; successMessage = null; showForm = true;
    }

    private void OpenEdit(License l)
    {
        editingId = l.Id;
        form = new LicenseForm { LicenseKey = l.LicenseKey, ProgramId = l.ProgramId, CompanyId = l.CompanyId, StartDate = l.StartDate, ExpiryDate = l.ExpiryDate, MaxMembers = l.MaxMembers, Status = l.Status };
        editingMembers = DbContext.LicenseMembers
            .Include(m => m.Customer).ThenInclude(c => c!.Company)
            .Where(m => m.LicenseId == l.Id).ToList();
        allCustomers = DbContext.Customers.Include(c => c.Company).OrderBy(c => c.FirstName).ToList();
        customerSearch = string.Empty; selectedCustomerIds = new(); memberError = null;
        isEditing = true; formError = null; successMessage = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; memberError = null; }

    private async Task AddSelectedMembers()
    {
        if (selectedCustomerIds.Count == 0) { memberError = "Please select at least one customer."; return; }
        memberError = null;
        try
        {
            foreach (var cid in selectedCustomerIds)
            {
                if (!DbContext.LicenseMembers.Any(m => m.LicenseId == editingId && m.CustomerId == cid))
                    DbContext.LicenseMembers.Add(new LicenseMember { LicenseId = editingId, CustomerId = cid, AssignedAt = DateTime.Today });
            }
            DbContext.SaveChanges();
            editingMembers = DbContext.LicenseMembers
                .Include(m => m.Customer).ThenInclude(c => c!.Company)
                .Where(m => m.LicenseId == editingId).ToList();
            selectedCustomerIds = new();
            await Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private async Task RemoveMember(LicenseMember m)
    {
        memberError = null;
        try
        {
            var entity = DbContext.LicenseMembers.Find(m.Id);
            if (entity != null) { DbContext.LicenseMembers.Remove(entity); DbContext.SaveChanges(); }
            editingMembers = DbContext.LicenseMembers
                .Include(em => em.Customer).ThenInclude(c => c!.Company)
                .Where(em => em.LicenseId == editingId).ToList();
            await Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private async Task Save()
    {
        if (form.ProgramId == 0) { formError = "Please select a program."; return; }
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var e = DbContext.Licenses.Find(editingId);
                if (e == null) { formError = "License not found."; return; }
                e.LicenseKey = form.LicenseKey; e.ProgramId = form.ProgramId; e.CompanyId = form.CompanyId;
                e.StartDate = form.StartDate; e.ExpiryDate = form.ExpiryDate; e.MaxMembers = form.MaxMembers; e.Status = form.Status;
                DbContext.Licenses.Update(e);
                successMessage = $"License '{e.LicenseKey}' updated.";
            }
            else
            {
                var e = new License { LicenseKey = form.LicenseKey, ProgramId = form.ProgramId, CompanyId = form.CompanyId, StartDate = form.StartDate, ExpiryDate = form.ExpiryDate, MaxMembers = form.MaxMembers, Status = form.Status, CreatedAt = DateTime.Now };
                DbContext.Licenses.Add(e);
                successMessage = $"License '{e.LicenseKey}' added.";
            }
            DbContext.SaveChanges();
            await Load();
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private sealed class LicenseForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string LicenseKey { get; set; } = string.Empty;
        public int   ProgramId  { get; set; }
        public int?  CompanyId  { get; set; }
        public DateTime StartDate  { get; set; } = DateTime.Today;
        public DateTime ExpiryDate { get; set; } = DateTime.Today.AddYears(1);
        public int   MaxMembers { get; set; } = 5;
        public string Status    { get; set; } = "Active";
    }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }
    .header-actions { display: flex; gap: .75rem; }
    .btn { border: none; padding: .65rem 1.25rem; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: .9rem; transition: opacity .2s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: #667eea; color: white; }
    .btn-success { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
    .alert { padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1.25rem; }
    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-info { background: #d1ecf1; color: #0c5460; }
    .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .alert-warning { background: #fff3cd; color: #856404; }
    .table-container { background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 1.5rem; }
    .data-table { width: 100%; border-collapse: collapse; font-size: .88rem; }
    .data-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .data-table th { padding: .9rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
    .data-table td { padding: .8rem 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .data-table tbody tr:hover { background: #f9f9f9; }
    .id-cell { font-weight: 600; color: #667eea; }
    .key-cell { font-family: monospace; font-size: .82rem; color: #444; }
    .count-cell { font-weight: 700; color: #764ba2; text-align: center; }
    .badge-program { background: #eef2ff; color: #667eea; padding: .2rem .65rem; border-radius: 10px; font-size: .78rem; font-weight: 600; }
    .badge-status { padding: .2rem .65rem; border-radius: 10px; font-size: .78rem; font-weight: 600; }
    .badge-status.active    { background: #d4edda; color: #155724; }
    .badge-status.expired   { background: #f8d7da; color: #721c24; }
    .badge-status.suspended { background: #fff3cd; color: #856404; }
    .btn-edit { background: #fff3cd; color: #856404; border: 1px solid #ffc107; padding: .3rem .75rem; border-radius: 4px; cursor: pointer; font-size: .82rem; }
    .btn-edit:hover { background: #ffc107; color: #fff; }
    .stats { background: white; padding: 1.25rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: 0; color: #555; }
    .loading { display: flex; flex-direction: column; justify-content: center; align-items: center; min-height: 200px; background: white; border-radius: 8px; }
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000; }
    .modal-panel { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.3); z-index: 1001; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0; color: white; }
    .modal-header h2 { margin: 0; font-size: 1.25rem; }
    .btn-close { background: rgba(255,255,255,.2); border: none; color: white; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; }
    .btn-close:hover { background: rgba(255,255,255,.35); }
    .modal-body { padding: 1.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 500; color: #444; margin-bottom: .35rem; font-size: .9rem; }
    .form-control { width: 100%; padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; box-sizing: border-box; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.15); }
    .modal-footer { display: flex; justify-content: flex-end; gap: .75rem; padding-top: 1rem; border-top: 1px solid #eee; margin-top: .5rem; }
    .section-divider { border: none; border-top: 2px solid #f0f0f0; margin: 1.25rem 0 1rem; }
    .members-section { background: #fafafa; border: 1px solid #e8e8e8; border-radius: 8px; padding: 1rem; }
    .members-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
    .members-title { font-weight: 700; color: #333; font-size: .95rem; }
    .members-count { background: #667eea; color: white; padding: .15rem .65rem; border-radius: 10px; font-size: .8rem; font-weight: 600; }
    .members-count.full { background: #dc3545; }
    .members-list { display: flex; flex-direction: column; gap: .4rem; margin-bottom: .75rem; max-height: 220px; overflow-y: auto; }
    .member-row { display: flex; justify-content: space-between; align-items: center; background: white; border: 1px solid #e0e0e0; border-radius: 6px; padding: .45rem .75rem; }
    .member-info { display: flex; flex-direction: column; gap: .05rem; }
    .member-name { font-weight: 600; color: #333; font-size: .88rem; }
    .member-company { color: #999; font-size: .76rem; }
    .member-meta { display: flex; align-items: center; gap: .6rem; }
    .member-date { color: #bbb; font-size: .76rem; white-space: nowrap; }
    .btn-remove { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; width: 22px; height: 22px; border-radius: 50%; cursor: pointer; font-size: .7rem; line-height: 1; padding: 0; display: inline-flex; align-items: center; justify-content: center; }
    .btn-remove:hover { background: #dc3545; color: white; border-color: #dc3545; }
    .no-members { color: #aaa; font-size: .87rem; font-style: italic; margin: .25rem 0 .75rem; }
    .customer-picker { display: flex; flex-direction: column; gap: .5rem; }
    .customer-search { font-size: .87rem; }
    .customer-grid { max-height: 190px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 6px; background: white; }
    .customer-item { display: flex; align-items: center; gap: .65rem; padding: .45rem .75rem; cursor: pointer; border-bottom: 1px solid #f5f5f5; transition: background .1s; }
    .customer-item:last-child { border-bottom: none; }
    .customer-item:hover { background: #f0f4ff; }
    .customer-item.selected { background: #eef2ff; }
    .customer-item input[type="checkbox"] { accent-color: #667eea; width: 15px; height: 15px; flex-shrink: 0; cursor: pointer; }
    .customer-item-info { display: flex; flex-direction: column; gap: .05rem; min-width: 0; }
    .customer-item-name { font-weight: 600; color: #333; font-size: .86rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .customer-item-sub { color: #aaa; font-size: .75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .no-customers { color: #aaa; font-size: .84rem; font-style: italic; padding: .75rem; margin: 0; text-align: center; }
    .picker-footer { display: flex; justify-content: space-between; align-items: center; }
    .picker-count { color: #667eea; font-size: .84rem; font-weight: 500; }
    .btn-sm { padding: .4rem .9rem; font-size: .85rem; white-space: nowrap; }
    @@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .page-header { flex-direction: column; gap: 1rem; } }
</style>
