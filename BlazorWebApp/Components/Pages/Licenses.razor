@page "/licenses"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Licenses</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Licenses</h1>
            <div class="header-actions">
                <button class="btn btn-success" @onclick="OpenAdd">+ Add License</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
                    <div class="columns-toggle">
                        <button class="btn btn-secondary" @onclick="ToggleColumnsMenu">Columns ▾</button>
                        @if (showColumnsMenu)
                        {
                            <div class="columns-dropdown">
                                <label><input type="checkbox" @bind="showIdColumn" /> ID</label>
                                <label><input type="checkbox" @bind="showLicenseKeyColumn" /> License Key</label>
                                <label><input type="checkbox" @bind="showProgramColumn" /> Program</label>
                                <label><input type="checkbox" @bind="showOwnerColumn" /> Owner</label>
                                <label><input type="checkbox" @bind="showCompanyColumn" /> Company</label>
                                <label><input type="checkbox" @bind="showCustomerGroupColumn" /> Customer Group</label>
                                <label><input type="checkbox" @bind="showTypeColumn" /> Type</label>
                                <label><input type="checkbox" @bind="showStatusColumn" /> Status</label>
                                <label><input type="checkbox" @bind="showMembersColumn" /> Members</label>
                                <label><input type="checkbox" @bind="showMaxColumn" /> Max</label>
                                <label><input type="checkbox" @bind="showStartColumn" /> Start</label>
                                <label><input type="checkbox" @bind="showExpiryColumn" /> Expiry</label>
                                <label><input type="checkbox" @bind="showActionsColumn" /> Actions</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="filters-section">
                <div class="filters-group">
                    <input type="text" class="form-control filter-select" placeholder="Search license key / owner / program..." @bind="licenseSearch" @bind:event="oninput" @bind:after="ApplyLicenseFilters" />
                    <select class="form-control filter-select" @bind="filterProgramId" @bind:after="ApplyLicenseFilters">
                        <option value="0">All Programs</option>
                        @foreach (var p in programs)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                    <select class="form-control filter-select" @bind="filterCompanyId" @bind:after="ApplyLicenseFilters">
                        <option value="">All Companies</option>
                        @foreach (var c in companies)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <select class="form-control filter-select" @bind="filterGroupId" @bind:after="ApplyLicenseFilters">
                        <option value="">All Groups</option>
                        @foreach (var g in customerGroups)
                        {
                            <option value="@g.Id">@g.Name</option>
                        }
                    </select>
                    <select class="form-control filter-select" @bind="filterType" @bind:after="ApplyLicenseFilters">
                        <option value="">All Types</option>
                        <option value="1">Team size</option>
                        <option value="2">Qty purchase</option>
                        <option value="3">Seminar</option>
                    </select>
                    <select class="form-control filter-select" @bind="filterStatus" @bind:after="ApplyLicenseFilters">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Expired">Expired</option>
                        <option value="Suspended">Suspended</option>
                    </select>
                    <button class="btn btn-secondary" @onclick="ClearFilters">Clear Filters</button>
                </div>
            </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (licenses == null)
        {
            <div class="loading"><div class="spinner-border" role="status"></div><p>Loading…</p></div>
        }
        else if (licenses.Count == 0)
        {
            <div class="alert alert-info">No licenses found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @if (showIdColumn) { <th>ID</th> }
                            @if (showLicenseKeyColumn) { <th>License Key</th> }
                            @if (showProgramColumn) { <th>Program</th> }
                            @if (showOwnerColumn) { <th>Owner</th> }
                            @if (showCompanyColumn) { <th>Company</th> }
                            @if (showCustomerGroupColumn) { <th>Customer Group</th> }
                            @if (showTypeColumn) { <th>Type</th> }
                            @if (showStatusColumn) { <th>Status</th> }
                            @if (showMembersColumn) { <th>Members</th> }
                            @if (showMaxColumn) { <th>Max</th> }
                            @if (showStartColumn) { <th>Start Date</th> }
                            @if (showExpiryColumn) { <th>Expiry Date</th> }
                            @if (showActionsColumn) { <th>Actions</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lic in licenses)
                        {
                            <tr>
                                @if (showIdColumn) { <td class="id-cell">@lic.Id</td> }
                                @if (showLicenseKeyColumn) { <td class="key-cell">@lic.LicenseKey</td> }
                                @if (showProgramColumn) { <td><span class="badge-program">@(lic.Program?.Name ?? "-")</span></td> }
                                @if (showOwnerColumn)
                                {
                                    <td>
                                        @if (lic.Owner is Customer owner)
                                        {
                                            <a href="/customers/edit/@owner.Id" class="customer-link">@owner.FirstName @owner.LastName</a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                }
                                @if (showCompanyColumn) { <td>@(lic.Owner?.Company?.Name ?? "-")</td> }
                                @if (showCustomerGroupColumn) { <td>@(lic.Owner?.CustomerGroup?.Name ?? "-")</td> }
                                @if (showTypeColumn) { <td>@lic.SubLicenseType</td> }
                                @if (showStatusColumn) { <td><span class="badge-status @lic.Status.ToLower()">@lic.Status</span></td> }
                                @if (showMembersColumn) { <td class="count-cell">@lic.Members.Count</td> }
                                @if (showMaxColumn) { <td class="count-cell">@lic.MaxMembers</td> }
                                @if (showStartColumn) { <td>@lic.StartDate.ToString("yyyy-MM-dd")</td> }
                                @if (showExpiryColumn) { <td>@lic.ExpiryDate.ToString("yyyy-MM-dd")</td> }
                                @if (showActionsColumn) { <td><button class="btn-edit" @onclick="() => OpenEdit(lic)">✏️ Edit</button></td> }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="stats">
                <p>
                    <strong>Total Licenses:</strong> @totalRecords &nbsp;|&nbsp;
                    <strong>Active:</strong> @licenses?.Count(l => l.Status == "Active") &nbsp;|&nbsp;
                    <strong>Page @currentPage of @totalPages</strong> (@((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, totalRecords) of @totalRecords)
                </p>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    <button class="btn btn-secondary" @onclick="() => GoToPage(1)" disabled="@(!hasPreviousPage)">First</button>
                    <button class="btn btn-secondary" @onclick="PreviousPage" disabled="@(!hasPreviousPage)">Previous</button>
                    
                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        var pageNum = i;
                        <button class="btn @(pageNum == currentPage ? "btn-primary" : "btn-outline-primary")" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    }
                    
                    <button class="btn btn-secondary" @onclick="NextPage" disabled="@(!hasNextPage)">Next</button>
                    <button class="btn btn-secondary" @onclick="() => GoToPage(totalPages)" disabled="@(!hasNextPage)">Last</button>
                </div>
            }
        }
    </div>

    @if (showForm)
    {
        <div class="modal-backdrop" @onclick="CloseForm"></div>
        <div class="modal-panel">
            <div class="modal-header">
                <h2>@(isEditing ? "Edit License" : "Add New License")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label>License Key *</label>
                        <InputNumber class="form-control" @bind-Value="form.LicenseKey" placeholder="e.g. 12345" />
                        <ValidationMessage For="@(() => form.LicenseKey)" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Program *</label>
                            <InputSelect class="form-control" @bind-Value="form.ProgramId">
                                <option value="0">— Select Program —</option>
                                @foreach (var p in programs)
                                {
                                    <option value="@p.Id">@p.Name (v@p.Version)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.ProgramId)" />
                        </div>
                        <div class="form-group">
                            <label>Company</label>
                            <InputSelect class="form-control" @bind-Value="form.CompanyId">
                                <option value="">— None —</option>
                                @foreach (var c in companies)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </InputSelect>
                        </div>
                                        <div class="form-group">
                            <label>Customer Group</label>
                            <InputSelect class="form-control" @bind-Value="form.CustomerGroupId">
                                <option value="">— None —</option>
                                @foreach (var g in customerGroups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>License Owner</label>
                            <InputSelect class="form-control" @bind-Value="form.OwnerId">
                                <option value="0">— Select Owner —</option>
                                @foreach (var c in owners)
                                {
                                    <option value="@c.Id">#@c.Id — @c.FirstName @c.LastName — @c.Email — @(c.CustomerGroup?.Name ?? "No group") — @(c.Company?.Name ?? "No company")</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.OwnerId)" />
                        </div>
                        <div class="form-group">
                            <label>Sub License Type</label>
                            <InputSelect class="form-control" @bind-Value="form.SubLicenseType">
                                <option value="1">Team size</option>
                                <option value="2">Qty purchase</option>
                                <option value="3">Seminar</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Start Date *</label>
                            <InputDate class="form-control" @bind-Value="form.StartDate" />
                        </div>
                        <div class="form-group">
                            <label>Expiry Date *</label>
                            <InputDate class="form-control" @bind-Value="form.ExpiryDate" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Max Members</label>
                            <InputNumber class="form-control" @bind-Value="form.MaxMembers" />
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <InputSelect class="form-control" @bind-Value="form.Status">
                                <option value="Active">Active</option>
                                <option value="Expired">Expired</option>
                                <option value="Suspended">Suspended</option>
                            </InputSelect>
                        </div>
                    </div>

                    @if (isEditing)
                    {
                        <hr class="section-divider" />
                        <div class="members-section">
                            <div class="members-header">
                                <span class="members-title">Assigned Customers</span>
                                <span class="members-count @(editingMembers.Count >= form.MaxMembers ? "full" : "")">
                                    @editingMembers.Count / @form.MaxMembers
                                </span>
                            </div>
                            <div class="share-summary">
                                <span>Sharing scope:</span>
                                <strong>@shareableScope</strong>
                                <span>Eligible customers:</span>
                                <strong>@shareableCustomerCount</strong>
                            </div>
                            @if (editingMembers.Count > 0)
                            {
                                <div class="members-list">
                                    @foreach (var m in editingMembers)
                                    {
                                        <div class="member-row">
                                            <div class="member-info">
                                                <span class="member-meta">ID: @m.Customer?.Id</span>
                                                <span class="member-name">@m.Customer?.FirstName @m.Customer?.LastName</span>
                                                <span class="member-company">Company: @(m.Customer?.Company?.Name ?? "—")</span>
                                                <span class="member-company">Group: @(m.Customer?.CustomerGroup?.Name ?? "—")</span>
                                            </div>
                                            <div class="member-controls">
                                                <select class="permission-select" @onchange="@((ChangeEventArgs e) => UpdateMemberPermission(m, ParsePermission(e.Value)))">
                                                    <option value="1" selected="@(m.Permission == 1)">Owner</option>
                                                    <option value="2" selected="@(m.Permission == 2)">Admin</option>
                                                    <option value="3" selected="@(m.Permission == 3)">Member</option>
                                                </select>
                                                <span class="member-date">@m.AssignedAt.ToString("yyyy-MM-dd")</span>
                                                <button type="button" class="btn-remove" @onclick="() => RemoveMember(m)" title="Remove">✕</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="no-members">No customers assigned yet.</p>
                            }
                            <div class="customer-picker">
                                <input class="form-control customer-search"
                                       placeholder="Search by name, company, city…"
                                       @bind="customerSearch" @bind:event="oninput" />
                                <div class="customer-grid">
                                    @{var avail = availableCustomers.ToList();}
                                    @if (avail.Count == 0)
                                    {
                                        <p class="no-customers">@(string.IsNullOrEmpty(customerSearch) ? "All customers already assigned." : "No customers match your search.")</p>
                                    }
                                    else
                                    {
                                        @foreach (var c in avail)
                                        {
                                            var cid = c.Id;
                                            var isSelected = selectedCustomerIds.Contains(cid);
                                            <label class="customer-item @(isSelected ? "selected" : "")">
                                                <input type="checkbox" checked="@isSelected" @onchange="() => ToggleCustomer(cid)" />
                                                <div class="customer-item-info">
                                                    <span class="customer-item-name">#@c.Id — @c.FirstName @c.LastName</span>
                                                    <span class="customer-item-sub">@(c.Company?.Name ?? "—") · @(c.CustomerGroup?.Name ?? "—")@(!string.IsNullOrEmpty(c.City) ? " · " + c.City : "")</span>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                                <div class="picker-footer">
                                    <span class="picker-count">@selectedCustomerIds.Count selected</span>
                                    <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedMembers"
                                            disabled="@(selectedCustomerIds.Count == 0 || editingMembers.Count >= form.MaxMembers)">
                                        + Add Selected (@selectedCustomerIds.Count)
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(memberError))
                            {
                                <div class="alert alert-danger" style="margin-top:.5rem;padding:.5rem .85rem;">@memberError</div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Add License"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<License>?      licenses;
    private List<AppProgram>    programs       = new();
    private List<Company>       companies      = new();
    private List<CustomerGroup> customerGroups = new();
    private List<LicenseMember> editingMembers = new();
    private List<Customer>      allCustomers   = new();
    private List<Customer>      owners         = new();
    private bool showForm, isEditing, isSaving;
    private bool showColumnsMenu;
    private bool showIdColumn = true;
    private bool showLicenseKeyColumn = true;
    private bool showProgramColumn = true;
    private bool showOwnerColumn = true;
    private bool showCompanyColumn = true;
    private bool showCustomerGroupColumn = true;
    private bool showTypeColumn = true;
    private bool showStatusColumn = true;
    private bool showMembersColumn = true;
    private bool showMaxColumn = true;
    private bool showStartColumn = true;
    private bool showExpiryColumn = true;
    private bool showActionsColumn = true;
    private string? successMessage, formError, memberError;
    private LicenseForm form = new();
    private int editingLicenseId;
    private string customerSearch = string.Empty;
    private string licenseSearch = string.Empty;
    private HashSet<int> selectedCustomerIds = new();
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalRecords = 0;

    // Filters
    private int filterProgramId;
    private int? filterCompanyId;
    private int? filterGroupId;
    private int? filterType;
    private string? filterStatus;

    private int totalPages => (int)Math.Ceiling((double)totalRecords / pageSize);
    private bool hasPreviousPage => currentPage > 1;
    private bool hasNextPage => currentPage < totalPages;

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            Load();
        }
    }

    private async Task PreviousPage()
    {
        if (hasPreviousPage)
        {
            currentPage--;
            Load();
        }
    }

    private async Task NextPage()
    {
        if (hasNextPage)
        {
            currentPage++;
            Load();
        }
    }
    private IEnumerable<Customer> availableCustomers => allCustomers
        .Where(c => !editingMembers.Any(m => m.CustomerId == c.Id))
        .Where(c => string.IsNullOrEmpty(customerSearch) ||
                    $"{c.FirstName} {c.LastName}".Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    (c.Company?.Name ?? "").Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    (c.CustomerGroup?.Name ?? "").Contains(customerSearch, StringComparison.OrdinalIgnoreCase) ||
                    c.City.Contains(customerSearch, StringComparison.OrdinalIgnoreCase));

    private int shareableCustomerCount => allCustomers.Count;
    private string shareableScope => form.CompanyId.HasValue
        ? $"Company: {companies.FirstOrDefault(c => c.Id == form.CompanyId)?.Name ?? "Unknown"}"
        : form.CustomerGroupId.HasValue
            ? $"Group: {customerGroups.FirstOrDefault(g => g.Id == form.CustomerGroupId)?.Name ?? "Unknown"}"
            : "None selected";

    private void ToggleCustomer(int id)
    {
        if (!selectedCustomerIds.Add(id)) selectedCustomerIds.Remove(id);
    }

    private void ToggleColumnsMenu()
    {
        showColumnsMenu = !showColumnsMenu;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        Load();
    }

    private void Load()
    {
        var query = DbContext.Licenses
            .Include(l => l.Program)
            .Include(l => l.Company)
            .Include(l => l.CustomerGroup)
            .Include(l => l.Owner)
                .ThenInclude(o => o!.Company)
            .Include(l => l.Owner)
                .ThenInclude(o => o!.CustomerGroup)
            .Include(l => l.Members)
            .AsQueryable();

        // Apply filters
        if (!string.IsNullOrWhiteSpace(licenseSearch))
        {
            var lowerSearch = licenseSearch.Trim().ToLower();
            if (int.TryParse(lowerSearch, out var licenseKeySearch))
            {
                query = query.Where(l => l.LicenseKey == licenseKeySearch ||
                                         l.Program!.Name!.ToLower().Contains(lowerSearch) ||
                                         (l.Owner != null && (l.Owner.FirstName.ToLower().Contains(lowerSearch) ||
                                                              l.Owner.LastName.ToLower().Contains(lowerSearch) ||
                                                              l.Owner.Email.ToLower().Contains(lowerSearch))));
            }
            else
            {
                query = query.Where(l => l.Program!.Name!.ToLower().Contains(lowerSearch) ||
                                         (l.Owner != null && (l.Owner.FirstName.ToLower().Contains(lowerSearch) ||
                                                              l.Owner.LastName.ToLower().Contains(lowerSearch) ||
                                                              l.Owner.Email.ToLower().Contains(lowerSearch))));
            }
        }

        if (filterProgramId > 0)
        {
            query = query.Where(l => l.ProgramId == filterProgramId);
        }
        if (filterCompanyId.HasValue)
        {
            query = query.Where(l => l.CompanyId == filterCompanyId.Value);
        }
        if (filterGroupId.HasValue)
        {
            query = query.Where(l => l.CustomerGroupId == filterGroupId.Value);
        }
        if (filterType.HasValue)
        {
            query = query.Where(l => (int)l.SubLicenseType == filterType.Value);
        }
        if (!string.IsNullOrEmpty(filterStatus))
        {
            query = query.Where(l => l.Status == filterStatus);
        }

        totalRecords = query.Count();
        licenses = query
            .OrderBy(l => l.LicenseKey)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

        // Ensure current page is valid
        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
            licenses = query
                .OrderBy(l => l.LicenseKey)
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
        }

        programs  = DbContext.Programs.OrderBy(p => p.Name).ToList();
        companies = DbContext.Companies.OrderBy(c => c.Name).ToList();
        customerGroups = DbContext.CustomerGroups.OrderBy(g => g.Name).ToList();
        owners = DbContext.Customers.Include(c => c.Company).Include(c => c.CustomerGroup).OrderBy(c => c.Id).ToList();
    }

    private Task RefreshData() { currentPage = 1; Load(); successMessage = null; StateHasChanged(); return Task.CompletedTask; }

    private async Task ClearFilters()
    {
        licenseSearch = string.Empty;
        filterProgramId = 0;
        filterCompanyId = null;
        filterGroupId = null;
        filterType = null;
        filterStatus = null;
        currentPage = 1;
        Load();
        StateHasChanged();
    }

    private void ApplyLicenseFilters()
    {
        currentPage = 1;
        Load();
        StateHasChanged();
    }

    private void OpenAdd()
    {
        form = new LicenseForm { StartDate = DateTime.Today, ExpiryDate = DateTime.Today.AddYears(1) };
        isEditing = false; formError = null; successMessage = null; showForm = true;
    }

    private void OpenEdit(License l)
    {
        editingLicenseId = l.Id;
        form = new LicenseForm { LicenseKey = l.LicenseKey, ProgramId = l.ProgramId, CompanyId = l.CompanyId, CustomerGroupId = l.CustomerGroupId, OwnerId = l.OwnerId ?? 0, SubLicenseType = l.SubLicenseType, StartDate = l.StartDate, ExpiryDate = l.ExpiryDate, MaxMembers = l.MaxMembers, Status = l.Status };
        editingMembers = DbContext.LicenseMembers
            .Include(m => m.Customer).ThenInclude(c => c!.Company)
            .Include(m => m.Customer).ThenInclude(c => c!.CustomerGroup)
            .Where(m => m.LicenseId == l.Id).ToList();
        allCustomers = DbContext.Customers
            .Include(c => c.Company)
            .Include(c => c.CustomerGroup)
            .Where(c => (l.CompanyId.HasValue && c.CompanyId == l.CompanyId) || (l.CustomerGroupId.HasValue && c.CustomerGroupId == l.CustomerGroupId))
            .OrderBy(c => c.FirstName).ToList();
        customerSearch = string.Empty; selectedCustomerIds = new(); memberError = null;
        isEditing = true; formError = null; successMessage = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; memberError = null; }

    private async Task AddSelectedMembers()
    {
        if (selectedCustomerIds.Count == 0) { memberError = "Please select at least one customer."; return; }
        memberError = null;
        try
        {
                var license = DbContext.Licenses.Find(editingLicenseId);
            if (license != null && license.SubLicenseType != LicenseType.Seminar && editingMembers.Count + selectedCustomerIds.Count > license.MaxMembers)
            {
                memberError = $"This license only supports {license.MaxMembers} members.";
                return;
            }

            foreach (var cid in selectedCustomerIds)
            {
                if (!DbContext.LicenseMembers.Any(m => m.LicenseId == editingLicenseId && m.CustomerId == cid))
                    DbContext.LicenseMembers.Add(new LicenseMember { LicenseId = editingLicenseId, CustomerId = cid, OwnerId = license?.OwnerId, AssignedAt = DateTime.Today, Permission = 3 });
            }
            DbContext.SaveChanges();
            editingMembers = DbContext.LicenseMembers
                .Include(m => m.Customer).ThenInclude(c => c!.Company)
                .Where(m => m.LicenseId == editingLicenseId).ToList();
            selectedCustomerIds = new();
            Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private async Task RemoveMember(LicenseMember m)
    {
        memberError = null;
        try
        {
            var entity = DbContext.LicenseMembers.Find(m.Id);
            if (entity != null) { DbContext.LicenseMembers.Remove(entity); DbContext.SaveChanges(); }
            editingMembers = DbContext.LicenseMembers
                .Include(em => em.Customer).ThenInclude(c => c!.Company)
                .Where(em => em.LicenseId == editingLicenseId).ToList();
            Load();
        }
        catch (Exception ex) { memberError = $"Error: {ex.Message}"; }
    }

    private void UpdateMemberPermission(LicenseMember m, int permission)
    {
        m.Permission = permission;
        var entity = DbContext.LicenseMembers.Find(m.Id);
        if (entity != null)
        {
            entity.Permission = permission;
            DbContext.LicenseMembers.Update(entity);
            DbContext.SaveChanges();
        }
    }

    private int ParsePermission(object? value)
    {
        if (value != null && int.TryParse(value.ToString(), out int permission))
        {
            return permission;
        }
        return 3; // Default to Member
    }

    private async Task Save()
    {
        if (form.ProgramId == 0) { formError = "Please select a program."; return; }
        if (form.OwnerId == 0) { formError = "Please select a license owner."; return; }
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var e = DbContext.Licenses.Find(editingLicenseId);
                if (e == null) { formError = "License not found."; return; }
                e.LicenseKey = form.LicenseKey; e.ProgramId = form.ProgramId; e.CompanyId = form.CompanyId; e.CustomerGroupId = form.CustomerGroupId;
                e.OwnerId = form.OwnerId == 0 ? null : form.OwnerId;
                e.SubLicenseType = form.SubLicenseType;
                e.StartDate = form.StartDate; e.ExpiryDate = form.ExpiryDate; e.MaxMembers = form.MaxMembers; e.Status = form.Status;
                e.UpdatedAt = DateTime.Now;
                DbContext.Licenses.Update(e);
                var membersToUpdate = DbContext.LicenseMembers.Where(m => m.LicenseId == editingLicenseId).ToList();
                foreach (var member in membersToUpdate)
                {
                    member.OwnerId = e.OwnerId;
                    DbContext.LicenseMembers.Update(member);
                }
                successMessage = $"License '{e.LicenseKey}' updated.";
            }
            else
            {
                var e = new License { LicenseKey = form.LicenseKey, ProgramId = form.ProgramId, CompanyId = form.CompanyId, CustomerGroupId = form.CustomerGroupId, OwnerId = form.OwnerId == 0 ? null : form.OwnerId, SubLicenseType = form.SubLicenseType, StartDate = form.StartDate, ExpiryDate = form.ExpiryDate, MaxMembers = form.MaxMembers, Status = form.Status, CreatedAt = DateTime.Now };
                DbContext.Licenses.Add(e);
                DbContext.SaveChanges(); // Save first to get the ID

                // Automatically add the owner as a LicenseMember with Owner permission
                if (e.OwnerId.HasValue)
                {
                    var ownerMember = new LicenseMember
                    {
                        LicenseId = e.Id,
                        CustomerId = e.OwnerId.Value,
                        OwnerId = e.OwnerId.Value,
                        Permission = 1, // Owner
                        AssignedAt = DateTime.Today,
                        CreatedAt = DateTime.Now
                    };
                    DbContext.LicenseMembers.Add(ownerMember);
                    DbContext.SaveChanges();
                }

                successMessage = $"License '{e.LicenseKey}' added.";
            }
            DbContext.SaveChanges();
            Load();
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private sealed class LicenseForm
    {
        [System.ComponentModel.DataAnnotations.Required] public int LicenseKey { get; set; }
        public int   ProgramId   { get; set; }
        public int   OwnerId     { get; set; }
        public int?  CompanyId   { get; set; }
        public int?  CustomerGroupId  { get; set; }
        public LicenseType SubLicenseType { get; set; } = LicenseType.TeamSize;
        public DateTime StartDate  { get; set; } = DateTime.Today;
        public DateTime ExpiryDate { get; set; } = DateTime.Today.AddYears(1);
        public int   MaxMembers { get; set; } = 5;
        public string Status    { get; set; } = "Active";
    }
}

