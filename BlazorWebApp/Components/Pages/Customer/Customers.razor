@page "/customers"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Customers</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">
        You are not authorized. Please <a href="/login">login</a> first.
    </div>
}
else
{
    <div class="customers-container">
        <div class="page-header">
            <h1>Customers</h1>
            <div class="header-actions">
                <button class="btn btn-primary" @onclick="AddNewCustomer">➕ Add New Customer</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="search-filters">
            <div class="search-group">
                <label>Search Customers</label>
                <input type="text" class="form-control search-input" placeholder="Search by name or email..." @bind="searchQuery" @bind:event="oninput" @bind:after="Search" />
            </div>
            <div class="filters-group">
                <div class="filter-group">
                    <label>Company</label>
                    <select class="form-control filter-select" @bind="filterCompanyId" @bind:after="ApplyCustomerFilters">
                        <option value="">Select Option</option>
                        @foreach (var c in companies)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label>Group</label>
                    <select class="form-control filter-select" @bind="filterGroupId" @bind:after="ApplyCustomerFilters">
                        <option value="">Select Option</option>
                        @foreach (var g in groups)
                        {
                            <option value="@g.Id">@g.Name</option>
                        }
                    </select>
                </div>
                <button class="btn btn-secondary" @onclick="ClearFilters">Clear Filters</button>
            </div>
        </div>

        @if (customers == null)
        {
            <div class="loading">
                <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
                <p>Loading customers...</p>
            </div>
        }
        else if (customers.Count == 0)
        {
            <div class="alert alert-info">No customers found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="customers-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Company</th>
                            <th>Group</th>
                            <th>City</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in paged)
                        {
                            <tr>
                                <td class="id-cell">@customer.Id</td>
                                <td>@customer.FirstName</td>
                                <td>@customer.LastName</td>
                                <td><a href="mailto:@customer.Email">@customer.Email</a></td>
                                <td><a href="tel:@customer.Phone">@customer.Phone</a></td>
                                <td>@(customer.Company?.Name ?? "-")</td>
                                <td><span class="badge-group">@(customer.CustomerGroup?.Name ?? "-")</span></td>
                                <td>@customer.City</td>
                                <td>@customer.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="actions-cell">
                                    <button type="button" class="btn-edit" @onclick="() => EditCustomer(customer)">✏️ Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (totalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="page-btn" disabled="@(currentPage == 1)" @onclick="() => GoToPage(currentPage - 1)">‹ Prev</button>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var p = i;
                        <button class="page-btn @(p == currentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                    }
                    <button class="page-btn" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(currentPage + 1)">Next ›</button>
                </div>
            }
            <div class="stats">
                <p><strong>Showing:</strong> @(((currentPage - 1) * PageSize) + 1)–@(Math.Min(currentPage * PageSize, customers!.Count)) of <strong>@customers.Count</strong> customers</p>
            </div>
        }
    </div>
}

@code {
    private List<Customer>? customers;
    private List<Company> companies = new();
    private List<CustomerGroup> groups = new();

    // Search and filters
    private string searchQuery = string.Empty;
    private int? filterCompanyId;
    private int? filterGroupId;
    private string? successMessage;

    private int currentPage = 1;
    private const int PageSize = 20;
    private int totalPages => (int)Math.Ceiling((customers?.Count ?? 0) / (double)PageSize);
    private List<Customer> paged => customers?.Skip((currentPage - 1) * PageSize).Take(PageSize).ToList() ?? new();
    private void GoToPage(int page) { currentPage = Math.Clamp(page, 1, Math.Max(1, totalPages)); }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        LoadAll();
    }

    private void LoadAll()
    {
        var query = DbContext.Customers
            .Include(c => c.Company)
            .Include(c => c.CustomerGroup)
            .AsQueryable();

        // Apply search
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var lowerSearch = searchQuery.Trim().ToLower();
            query = query.Where(c => c.FirstName.ToLower().Contains(lowerSearch) ||
                                     c.LastName.ToLower().Contains(lowerSearch) ||
                                     c.Email.ToLower().Contains(lowerSearch));
        }

        // Apply filters
        if (filterCompanyId.HasValue)
        {
            query = query.Where(c => c.CompanyId == filterCompanyId.Value);
        }
        if (filterGroupId.HasValue)
        {
            query = query.Where(c => c.CustomerGroupId == filterGroupId.Value);
        }

        customers = query.OrderBy(c => c.Id).ToList();

        companies = DbContext.Companies.OrderBy(c => c.Name).ToList();
        groups    = DbContext.CustomerGroups.OrderBy(g => g.Name).ToList();
        currentPage = 1;
    }

    private Task RefreshData()
    {
        LoadAll();
        successMessage = "✓ Data refreshed from database";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void Search()
    {
        LoadAll();
        StateHasChanged();
    }

    private void ApplyCustomerFilters()
    {
        currentPage = 1;
        LoadAll();
        StateHasChanged();
    }

    private async Task ClearFilters()
    {
        searchQuery = string.Empty;
        filterCompanyId = null;
        filterGroupId = null;
        currentPage = 1;
        LoadAll();
        StateHasChanged();
    }

    private void AddNewCustomer()
    {
        Navigation.NavigateTo("/customers/add");
    }

    private void EditCustomer(Customer customer)
    {
        Navigation.NavigateTo($"/customers/edit/{customer.Id}");
    }
}

<style>
    .customers-container {
        padding: 2rem;
        background-color: #f5f5f5;
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        background: white;
        padding: 1.5rem;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }

    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }

    .header-actions { display: flex; gap: .75rem; }

    .search-filters {
        background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1);
        margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
    }
    .search-group { flex: 1; min-width: 200px; display: flex; flex-direction: column; gap: .35rem; }
    .search-group label,
    .filter-group label { font-weight: 500; color: #555; font-size: .88rem; }
    .search-input { width: 100%; padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; }
    .filters-group { display: flex; gap: .75rem; align-items: flex-end; flex-wrap: wrap; }
    .filter-group { display: flex; flex-direction: column; gap: .35rem; min-width: 150px; }
    .filter-select { padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; min-width: 150px; }

    .btn {
        border: none; padding: .65rem 1.25rem; border-radius: 4px;
        cursor: pointer; font-weight: 500; font-size: .9rem; transition: opacity .2s;
    }
    .btn:hover { opacity: .85; }
    .btn-primary   { background: #667eea; color: white; }
    .btn-success   { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }

    .alert { padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1.25rem; }
    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-info    { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }
    .alert-danger  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .alert-warning { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }

    .table-container {
        background: white; border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 1.5rem;
    }

    .customers-table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    .customers-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .customers-table th { padding: .85rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
    .customers-table td { padding: .85rem 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .customers-table tbody tr:hover { background: #f9f9f9; }
    .customers-table a { color: #667eea; text-decoration: none; }
    .customers-table a:hover { text-decoration: underline; }

    .id-cell { font-weight: 600; color: #667eea; }
    .actions-cell { white-space: nowrap; }

    .badge-group {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white; padding: .2rem .6rem; border-radius: 12px;
        font-size: .78rem; font-weight: 500;
    }

    .btn-edit {
        background: #fff3cd; color: #856404; border: 1px solid #ffc107;
        padding: .3rem .75rem; border-radius: 4px; cursor: pointer; font-size: .82rem;
        transition: background .2s;
    }
    .btn-edit:hover { background: #ffc107; color: #fff; }

    .pagination-bar { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: .35rem; padding: 1rem; background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); margin-bottom: 1rem; }
    .page-btn { border: 1px solid #d0d0d0; background: white; color: #555; padding: .35rem .7rem; border-radius: 4px; cursor: pointer; font-size: .88rem; min-width: 36px; transition: all .15s; }
    .page-btn:hover:not(:disabled) { background: #667eea; color: white; border-color: #667eea; }
    .page-btn.active { background: #667eea; color: white; border-color: #667eea; font-weight: 600; }
    .page-btn:disabled { opacity: .45; cursor: not-allowed; }
    .stats { background: white; padding: 1.25rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: 0; color: #555; }

    .loading {
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        min-height: 200px; background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }
    .spinner-border { color: #667eea; }

    @@media (max-width: 600px) {
        .form-row { grid-template-columns: 1fr; }
        .page-header { flex-direction: column; gap: 1rem; }
        .customers-table { font-size: .8rem; }
        .customers-table th, .customers-table td { padding: .65rem; }
    }
</style>
