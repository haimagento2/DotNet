@page "/customers/edit/{id:int}"
@rendermode InteractiveServer
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>@(customer == null ? "Customer Not Found" : $"Edit {customer.FirstName} {customer.LastName}")</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">
        You are not authorized. Please <a href="/login">login</a> first.
    </div>
}
else if (customer == null)
{
    <div class="alert alert-danger">Customer not found.</div>
}
else
{
    <div class="customer-edit-container">
        <div class="page-header">
            <h1>Edit Customer</h1>
            <div class="header-actions">
                <button class="btn btn-secondary" @onclick="GoBack">← Back to Customers</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="edit-form-container">
            <div class="customer-edit-grid">
                <aside class="customer-edit-sidebar">
                    <div class="sidebar-card">
                        <div class="sidebar-title">Customer Information</div>
                        <button type="button" class="sidebar-item @(activeSection == CustomerSection ? "active" : "")" @onclick="() => SetSection(CustomerSection)">
                            Account Information
                        </button>
                        <div class="sidebar-divider"></div>
                        <button type="button" class="sidebar-item @(activeSection == LicenseSection ? "active" : "")" @onclick="() => SetSection(LicenseSection)">
                            Licenses
                        </button>
                    </div>
                </aside>

                <div class="customer-edit-main">
                    @if (activeSection == CustomerSection)
                    {
                        <section class="section-card" id="customer-information">
                            <div class="section-card-header">
                                <h2>Customer Information</h2>
                            </div>

                            <EditForm Model="formModel" OnValidSubmit="SaveCustomer">
                                <DataAnnotationsValidator />

                                <div class="form-row">
                                    <div class="form-group">
                                        <label>First Name *</label>
                                        <InputText class="form-control" @bind-Value="formModel.FirstName" placeholder="First name" />
                                        <ValidationMessage For="@(() => formModel.FirstName)" />
                                    </div>
                                    <div class="form-group">
                                        <label>Last Name *</label>
                                        <InputText class="form-control" @bind-Value="formModel.LastName" placeholder="Last name" />
                                        <ValidationMessage For="@(() => formModel.LastName)" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label>Email *</label>
                                    <InputText class="form-control" @bind-Value="formModel.Email" placeholder="email@example.com" />
                                    <ValidationMessage For="@(() => formModel.Email)" />
                                </div>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Phone</label>
                                        <InputText class="form-control" @bind-Value="formModel.Phone" placeholder="+1-555-0000" />
                                    </div>
                                    <div class="form-group">
                                        <label>City</label>
                                        <InputText class="form-control" @bind-Value="formModel.City" placeholder="City" />
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Company</label>
                                        <InputSelect class="form-control" @bind-Value="formModel.CompanyId">
                                            <option value="">— None —</option>
                                            @foreach (var c in companies)
                                            {
                                                <option value="@c.Id">@c.Name</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="form-group">
                                        <label>Customer Group</label>
                                        <InputSelect class="form-control" @bind-Value="formModel.CustomerGroupId">
                                            <option value="">— None —</option>
                                            @foreach (var g in groups)
                                            {
                                                <option value="@g.Id">@g.Name</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(formError))
                                {
                                    <div class="alert alert-danger">@formError</div>
                                }

                                <div class="form-actions">
                                    <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                        @(isSaving ? "Saving…" : "Save Changes")
                                    </button>
                                </div>
                            </EditForm>
                        </section>
                    }

                    @if (activeSection == LicenseSection)
                    {
                        <section class="section-card" id="license-section">
                            <div class="section-card-header">
                                <h2>Licenses</h2>
                                <button class="btn btn-primary" @onclick="ShowAddLicenseForm">+ Add New License</button>
                            </div>

                            @if (showAddLicenseForm)
                            {
                                <div class="add-license-form">
                                    <EditForm Model="licenseForm" OnValidSubmit="SaveNewLicense" Context="licenseContext">
                                        <DataAnnotationsValidator />

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>License Key *</label>
                                                <InputText class="form-control" @bind-Value="licenseForm.LicenseKey" placeholder="e.g. ABC123" />
                                                <ValidationMessage For="@(() => licenseForm.LicenseKey)" />
                                            </div>
                                            <div class="form-group">
                                                <label>Program *</label>
                                                <InputSelect class="form-control" @bind-Value="licenseForm.ProgramId">
                                                    <option value="0">— Select Program —</option>
                                                    @foreach (var p in programs)
                                                    {
                                                        <option value="@p.Id">@p.Name (v@p.Version)</option>
                                                    }
                                                </InputSelect>
                                                <ValidationMessage For="@(() => licenseForm.ProgramId)" />
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Sub License Type *</label>
                                                <InputSelect class="form-control" @bind-Value="licenseForm.SubLicenseType">
                                                    <option value="@((int)LicenseType.TeamSize)">Team size</option>
                                                    <option value="@((int)LicenseType.QtyPurchase)">Qty purchase</option>
                                                    <option value="@((int)LicenseType.Seminar)">Seminar</option>
                                                </InputSelect>
                                            </div>
                                            <div class="form-group">
                                                <label>Max Members</label>
                                                <InputNumber class="form-control" @bind-Value="licenseForm.MaxMembers" />
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Start Date *</label>
                                                <InputDate class="form-control" @bind-Value="licenseForm.StartDate" />
                                            </div>
                                            <div class="form-group">
                                                <label>Expiry Date *</label>
                                                <InputDate class="form-control" @bind-Value="licenseForm.ExpiryDate" />
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <InputSelect class="form-control" @bind-Value="licenseForm.Status">
                                                    <option value="Active">Active</option>
                                                    <option value="Expired">Expired</option>
                                                    <option value="Suspended">Suspended</option>
                                                    <option value="Cancel">Cancel</option>
                                                </InputSelect>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(licenseFormError))
                                        {
                                            <div class="alert alert-danger">@licenseFormError</div>
                                        }

                                        <div class="form-actions">
                                            <button type="button" class="btn btn-secondary" @onclick="HideAddLicenseForm">Cancel</button>
                                            <button type="submit" class="btn btn-primary" disabled="@isSavingLicense">Add License</button>
                                        </div>
                                    </EditForm>
                                </div>
                            }

                            @if (customerLicenses.Count == 0)
                            {
                                <p class="no-licenses">No licenses assigned</p>
                            }
                            else
                            {
                                <div class="licenses-table">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>License Key</th>
                                                <th>Program</th>
                                                <th>Status</th>
                                                <th>Role</th>
                                                <th>Start Date</th>
                                                <th>Expiry Date</th>
                                                <th>Type</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var lic in customerLicenses)
                                            {
                                                <tr>
                                                    <td><strong>@lic.License.LicenseKey</strong></td>
                                                    <td>@lic.License.Program?.Name</td>
                                                    <td>
                                                        <span class="status-badge" data-status="@lic.License.Status">
                                                            @lic.License.Status
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="role-badge" data-role="@lic.Role">
                                                            @lic.Role
                                                        </span>
                                                    </td>
                                                    <td>@lic.License.StartDate.ToString("yyyy-MM-dd")</td>
                                                    <td>@lic.License.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                                    <td>@lic.License.SubLicenseType</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </section>
                    }

                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Customer? customer;
    private List<Company> companies = new();
    private List<CustomerGroup> groups = new();
    private List<CustomerLicenseInfo> customerLicenses = new();
    private bool isSaving;
    private string? successMessage;
    private string? formError;
    private CustomerFormModel formModel = new();

    private const string CustomerSection = "customer";
    private const string LicenseSection = "license";

    // License form
    private bool showAddLicenseForm;
    private string activeSection = CustomerSection;
    private List<AppProgram> programs = new();
    private bool isSavingLicense;
    private string? licenseFormError;
    private LicenseFormModel licenseForm = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        customer = DbContext.Customers
            .Include(c => c.Company)
            .Include(c => c.CustomerGroup)
            .FirstOrDefault(c => c.Id == Id);

        if (customer == null)
        {
            return;
        }

        companies = DbContext.Companies.OrderBy(c => c.Name).ToList();
        groups = DbContext.CustomerGroups.OrderBy(g => g.Name).ToList();
        programs = DbContext.Programs.OrderBy(p => p.Name).ToList();

        formModel = new CustomerFormModel
        {
            FirstName = customer.FirstName,
            LastName = customer.LastName,
            Email = customer.Email,
            Phone = customer.Phone,
            City = customer.City,
            CompanyId = customer.CompanyId,
            CustomerGroupId = customer.CustomerGroupId
        };

        LoadCustomerLicenses();
    }

    private void LoadCustomerLicenses()
    {
        if (customer == null) return;

        customerLicenses = new();

        // Get licenses where customer is owner
        var ownerLicenses = DbContext.Licenses
            .Include(l => l.Program)
            .Include(l => l.Members)
            .Where(l => l.OwnerId == customer.Id)
            .ToList();

        foreach (var lic in ownerLicenses)
        {
            customerLicenses.Add(new CustomerLicenseInfo
            {
                License = lic,
                Role = "Owner",
                Permission = 1
            });
        }

        // Get licenses where customer is a member (check LicenseMembers)
        var memberRecords = DbContext.LicenseMembers
            .Include(lm => lm.License)
            .ThenInclude(l => l.Program)
            .Where(lm => lm.CustomerId == customer.Id)
            .ToList();

        foreach (var member in memberRecords)
        {
            if (member.License != null)
            {
                var role = member.Permission switch
                {
                    1 => "Owner",
                    2 => "Admin",
                    _ => "Member"
                };
                customerLicenses.Add(new CustomerLicenseInfo
                {
                    License = member.License,
                    Role = role,
                    Permission = member.Permission
                });
            }
        }

        customerLicenses = customerLicenses
            .DistinctBy(x => x.License.Id)
            .OrderByDescending(x => x.License.StartDate)
            .ToList();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/customers");
    }

    private async Task SaveCustomer()
    {
        if (customer == null) return;

        isSaving = true;
        formError = null;

        try
        {
            customer.FirstName = formModel.FirstName;
            customer.LastName = formModel.LastName;
            customer.Email = formModel.Email;
            customer.Phone = formModel.Phone ?? string.Empty;
            customer.City = formModel.City ?? string.Empty;
            customer.CompanyId = formModel.CompanyId;
            customer.CustomerGroupId = formModel.CustomerGroupId;
            customer.UpdatedAt = DateTime.Now;

            DbContext.Customers.Update(customer);
            DbContext.SaveChanges();

            successMessage = $"Customer '{customer.FirstName} {customer.LastName}' updated successfully.";
        }
        catch (Exception ex)
        {
            formError = ex.InnerException is not null
                ? $"Error: {ex.Message} - {ex.InnerException.Message}"
                : $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowAddLicenseForm()
    {
        SetSection("license");
        showAddLicenseForm = true;
        licenseForm = new LicenseFormModel
        {
            OwnerId = customer!.Id,
            StartDate = DateTime.Now,
            ExpiryDate = DateTime.Now.AddYears(1),
            MaxMembers = 5,
            Status = "Active",
            SubLicenseType = LicenseType.TeamSize
        };
    }

    private void SetSection(string section)
    {
        activeSection = section;
        if (section != "license")
        {
            showAddLicenseForm = false;
        }
    }

    private void HideAddLicenseForm()
    {
        showAddLicenseForm = false;
        licenseForm = new LicenseFormModel();
        licenseFormError = null;
    }

    private async Task SaveNewLicense()
    {
        if (customer == null) return;

        isSavingLicense = true;
        licenseFormError = null;

        try
        {
            var newLicense = new License
            {
                LicenseKey = licenseForm.LicenseKey,
                ProgramId = licenseForm.ProgramId,
                OwnerId = licenseForm.OwnerId,
                SubLicenseType = licenseForm.SubLicenseType,
                StartDate = licenseForm.StartDate,
                ExpiryDate = licenseForm.ExpiryDate,
                MaxMembers = licenseForm.MaxMembers,
                Status = licenseForm.Status,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now
            };

            DbContext.Licenses.Add(newLicense);
            DbContext.SaveChanges();

            successMessage = $"License '{newLicense.LicenseKey}' added successfully.";
            LoadCustomerLicenses();
            HideAddLicenseForm();
        }
        catch (Exception ex)
        {
            licenseFormError = $"Error: {ex.Message}";
        }
        finally
        {
            isSavingLicense = false;
        }
    }

    private sealed class CustomerFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        public string? Phone { get; set; }
        public string? City { get; set; }
        public int? CompanyId { get; set; }
        public int? CustomerGroupId { get; set; }
    }

    private sealed class LicenseFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string LicenseKey { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Please select a program.")]
        public int ProgramId { get; set; }

        public int OwnerId { get; set; }
        public LicenseType SubLicenseType { get; set; } = LicenseType.TeamSize;

        [System.ComponentModel.DataAnnotations.Required]
        public DateTime StartDate { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public DateTime ExpiryDate { get; set; }

        public int MaxMembers { get; set; } = 5;
        public string Status { get; set; } = "Active";
    }

    private class CustomerLicenseInfo
    {
        public License License { get; set; } = null!;
        public string Role { get; set; } = string.Empty;
        public int Permission { get; set; } = 3; // 1=Owner, 2=Admin, 3=Member
    }
}

<style>
    .customer-edit-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }
    .header-actions { display: flex; gap: .75rem; }
    .edit-form-container { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); max-width: 1200px; margin: 0 auto; }
    .customer-edit-grid { display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem; align-items: flex-start; }
    .customer-edit-sidebar { display: flex; flex-direction: column; gap: 1rem; }
    .sidebar-card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1rem 0.75rem 1rem; box-shadow: 0 1px 3px rgba(0,0,0,.04); }
    .sidebar-title { font-size: .9rem; font-weight: 700; color: #111827; margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .04em; }
    .sidebar-item { width: 100%; text-align: left; background: transparent; border: none; padding: .9rem 1rem; margin-bottom: .4rem; color: #374151; font-size: .95rem; border-radius: 8px; cursor: pointer; transition: background .2s, color .2s; }
    .sidebar-item:hover { background: #f3f4f6; }
    .sidebar-item.active { background: #2563eb; color: white; }
    .sidebar-divider { height: 1px; background: #e5e7eb; margin: .4rem 0; }
    .customer-edit-main { display: flex; flex-direction: column; gap: 1.5rem; }
    .section-card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; }
    .section-card-header { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .section-card-header h2 { margin: 0; font-size: 1.4rem; color: #111827; }
    .section-card h2 { margin: 0; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 500; color: #444; margin-bottom: .35rem; font-size: .9rem; }
    .form-control { width: 100%; padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; box-sizing: border-box; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.15); }
    .form-actions { display: flex; justify-content: flex-end; gap: .75rem; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #eee; }
    .btn { border: none; padding: .65rem 1.25rem; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: .9rem; transition: opacity .2s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: #667eea; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
    .alert { padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1.25rem; }
    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .alert-warning { background: #fff3cd; color: #856404; }
    @@media (max-width: 900px) {
        .customer-edit-grid { grid-template-columns: 1fr; }
        .customer-edit-sidebar { order: 2; }
        .customer-edit-main { order: 1; }
        .form-row { grid-template-columns: 1fr; }
        .page-header { flex-direction: column; gap: 1rem; }
    }

    /* License Section Styles */
    .license-section { margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid #e0e0e0; }
    .license-section h3 { color: #333; font-size: 1.4rem; margin-bottom: 1.5rem; font-weight: 600; }
    .no-licenses { color: #666; font-style: italic; padding: 1rem; background: #f9f9f9; border-radius: 4px; }
    .licenses-table { overflow-x: auto; }
    .licenses-table table { width: 100%; border-collapse: collapse; background: white; }
    .licenses-table th { background: #f5f5f5; padding: 0.85rem; text-align: left; font-weight: 600; color: #333; border-bottom: 2px solid #ddd; font-size: 0.9rem; }
    .licenses-table td { padding: 0.85rem; border-bottom: 1px solid #eee; font-size: 0.9rem; }
    .licenses-table tbody tr:hover { background: #f9f9f9; }
    .status-badge { display: inline-block; padding: 0.35rem 0.65rem; border-radius: 4px; font-size: 0.85rem; font-weight: 500; }
    .status-badge[data-status="Active"] { background: #d4edda; color: #155724; }
    .status-badge[data-status="Suspended"] { background: #fff3cd; color: #856404; }
    .status-badge[data-status="Expired"] { background: #f8d7da; color: #721c24; }
    .status-badge[data-status="Cancel"] { background: #e2e3e5; color: #6c757d; }
    .role-badge { display: inline-block; padding: 0.35rem 0.65rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600; }
    .role-badge[data-role="Owner"] { background: #fff3cd; color: #856404; }
    .role-badge[data-role="Admin"] { background: #d1ecf1; color: #0c5460; }
    .role-badge[data-role="Member"] { background: #d4edda; color: #155724; }

    /* Add License Form Styles */
    .license-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .license-header h3 { margin: 0; }
    .add-license-form { background: #f9f9f9; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid #e0e0e0; }
    .add-license-form .form-row { margin-bottom: 1rem; }
    .add-license-form .form-group { margin-bottom: 1rem; }
    .add-license-form .form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.5rem; }
</style>