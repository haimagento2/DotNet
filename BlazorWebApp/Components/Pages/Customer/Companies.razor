@page "/companies"
@using BlazorWebApp.Data
@using BlazorWebApp.Models
@using Microsoft.EntityFrameworkCore
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Companies</PageTitle>

@if (!AuthService.IsAuthenticated())
{
    <div class="alert alert-warning">You are not authorized. Please <a href="/login">login</a> first.</div>
}
else
{
    <div class="page-container">
        <div class="page-header">
            <h1>Companies</h1>
            <div class="header-actions">
                <button class="btn btn-success" @onclick="OpenAdd">+ Add Company</button>
                <button class="btn btn-secondary" @onclick="RefreshData">🔄 Refresh</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="filter-bar">
            <div class="filter-group">
                <label>Search Companies</label>
                <input class="form-control" placeholder="Search by company, industry, city, email, website or customer…" @bind="filterCompanySearch" @bind:event="oninput" @bind:after="ResetPage" />
            </div>
        </div>

        @if (companies == null)
        {
            <div class="loading">
                <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
                <p>Loading companies...</p>
            </div>
        }
        else if (companies.Count == 0)
        {
            <div class="alert alert-info">No companies found.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Industry</th>
                            <th>City</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Website</th>
                            <th>Customers</th>
                            <th>Since</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var company in paged)
                        {
                            <tr>
                                <td class="id-cell">@company.Id</td>
                                <td class="name-cell">@company.Name</td>
                                <td><span class="badge-industry">@company.Industry</span></td>
                                <td>@company.City</td>
                                <td><a href="tel:@company.Phone">@company.Phone</a></td>
                                <td><a href="mailto:@company.Email">@company.Email</a></td>
                                <td><a href="https://@company.Website" target="_blank">@company.Website</a></td>
                                <td class="count-cell">@company.Customers.Count</td>
                                <td>@company.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td><button class="btn-edit" @onclick="() => OpenEdit(company)">✏️ Edit</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (totalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="page-btn" disabled="@(currentPage == 1)" @onclick="() => GoToPage(currentPage - 1)">‹ Prev</button>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var p = i;
                        <button class="page-btn @(p == currentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                    }
                    <button class="page-btn" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(currentPage + 1)">Next ›</button>
                </div>
            }
            <div class="stats"><p><strong>Showing:</strong> @(((currentPage - 1) * PageSize) + 1)–@(Math.Min(currentPage * PageSize, filteredCompanies.Count)) of <strong>@filteredCompanies.Count</strong> companies</p></div>
        }
    </div>

    @if (showForm)
    {
        <div class="modal-backdrop" @onclick="CloseForm"></div>
        <div class="modal-panel">
            <div class="modal-header">
                <h2>@(isEditing ? "Edit Company" : "Add New Company")</h2>
                <button class="btn-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />

                    <div class="form-row">
                        <div class="form-group">
                            <label>Company Name *</label>
                            <InputText class="form-control" @bind-Value="form.Name" placeholder="e.g. Acme Corp" />
                            <ValidationMessage For="@(() => form.Name)" />
                        </div>
                        <div class="form-group">
                            <label>Industry *</label>
                            <InputText class="form-control" @bind-Value="form.Industry" placeholder="e.g. Technology" />
                            <ValidationMessage For="@(() => form.Industry)" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>City</label>
                            <InputText class="form-control" @bind-Value="form.City" placeholder="City" />
                        </div>
                        <div class="form-group">
                            <label>Phone</label>
                            <InputText class="form-control" @bind-Value="form.Phone" placeholder="+1-555-0000" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Email</label>
                            <InputText class="form-control" @bind-Value="form.Email" placeholder="contact@company.com" />
                            <ValidationMessage For="@(() => form.Email)" />
                        </div>
                        <div class="form-group">
                            <label>Website</label>
                            <InputText class="form-control" @bind-Value="form.Website" placeholder="company.com" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving…" : (isEditing ? "Save Changes" : "Add Company"))
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private List<Company>? companies;
    private bool showForm, isEditing, isSaving;
    private string? successMessage, formError;
    private CompanyForm form = new();
    private int editingId;

    private int currentPage = 1;
    private const int PageSize = 20;
    private string filterCompanySearch = string.Empty;
    private List<Company> filteredCompanies => string.IsNullOrWhiteSpace(filterCompanySearch)
        ? companies ?? new()
        : (companies ?? new()).Where(c =>
            (c.Name ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
            (c.Industry ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
            (c.City ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
            (c.Email ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
            (c.Website ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
            c.Customers.Any(cust =>
                ($"{cust.FirstName} {cust.LastName}".Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase) ||
                (cust.Email ?? string.Empty).Contains(filterCompanySearch, StringComparison.OrdinalIgnoreCase))))
            .ToList();
    private int totalPages => (int)Math.Ceiling(filteredCompanies.Count / (double)PageSize);
    private List<Company> paged => filteredCompanies.Skip((currentPage - 1) * PageSize).Take(PageSize).ToList();
    private void GoToPage(int page) { currentPage = Math.Clamp(page, 1, Math.Max(1, totalPages)); }
    private void ResetPage() { currentPage = 1; }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated()) { Navigation.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        // Clear change tracker to ensure fresh data from database
        DbContext.ChangeTracker.Clear();

        companies = DbContext.Companies
            .AsNoTracking() // Ensure fresh data from database
            .Include(c => c.Customers)
            .OrderBy(c => c.Id)
            .ToList();
        currentPage = 1;
    }

    private async Task RefreshData()
    {
        await Load();
        successMessage = "✓ Data refreshed from database";
        StateHasChanged();
    }

    private void OpenAdd()
    {
        form = new(); isEditing = false; formError = null; successMessage = null; showForm = true;
    }

    private void OpenEdit(Company c)
    {
        editingId = c.Id;
        form = new CompanyForm { Name = c.Name, Industry = c.Industry, City = c.City, Phone = c.Phone, Email = c.Email, Website = c.Website };
        isEditing = true; formError = null; successMessage = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        isSaving = true; formError = null;
        try
        {
            if (isEditing)
            {
                var entity = DbContext.Companies.Find(editingId);
                if (entity == null) { formError = "Company not found."; return; }
                entity.Name = form.Name; entity.Industry = form.Industry; entity.City = form.City;
                entity.Phone = form.Phone; entity.Email = form.Email; entity.Website = form.Website;
                entity.UpdatedAt = DateTime.Now;
                DbContext.Companies.Update(entity);
                successMessage = $"Company '{entity.Name}' updated.";
            }
            else
            {
                var entity = new Company { Name = form.Name, Industry = form.Industry, City = form.City, Phone = form.Phone, Email = form.Email, Website = form.Website, CreatedAt = DateTime.Now };
                DbContext.Companies.Add(entity);
                successMessage = $"Company '{entity.Name}' added.";
            }
            DbContext.SaveChanges();
            await Load();
            showForm = false;
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private sealed class CompanyForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Industry is required")]
        public string Industry { get; set; } = string.Empty;

        public string City    { get; set; } = string.Empty;
        public string Phone   { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email")]
        public string Email   { get; set; } = string.Empty;

        public string Website { get; set; } = string.Empty;
    }
}

<style>
    .page-container { padding: 2rem; background: #f5f5f5; min-height: 100vh; }

    .page-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 1.5rem; background: white; padding: 1.5rem;
        border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }
    .page-header h1 { margin: 0; color: #333; font-size: 2rem; }
    .header-actions { display: flex; gap: .75rem; }

    .btn { border: none; padding: .65rem 1.25rem; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: .9rem; transition: opacity .2s; }
    .btn:hover { opacity: .85; }
    .btn-primary   { background: #667eea; color: white; }
    .btn-success   { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }

    .alert { padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1.25rem; }
    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-info    { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }
    .alert-danger  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .alert-warning { background: #fff3cd; color: #856404; }

    .filter-bar { background: white; padding: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); margin-bottom: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap; }
    .filter-group { display: flex; flex-direction: column; gap: .3rem; min-width: 280px; }
    .filter-group label { font-weight: 500; color: #555; font-size: .88rem; }

    .table-container { background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); overflow-x: auto; margin-bottom: 1.5rem; }
    .data-table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    .data-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .data-table th { padding: .9rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
    .data-table td { padding: .85rem 1rem; border-bottom: 1px solid #e0e0e0; color: #555; }
    .data-table tbody tr:hover { background: #f9f9f9; }
    .data-table a { color: #667eea; text-decoration: none; }
    .data-table a:hover { text-decoration: underline; }

    .id-cell { font-weight: 600; color: #667eea; }
    .name-cell { font-weight: 600; color: #333; }
    .count-cell { font-weight: 700; color: #764ba2; text-align: center; }
    .badge-industry { background: #eef2ff; color: #667eea; padding: .2rem .7rem; border-radius: 12px; font-size: .8rem; font-weight: 500; }

    .btn-edit { background: #fff3cd; color: #856404; border: 1px solid #ffc107; padding: .3rem .75rem; border-radius: 4px; cursor: pointer; font-size: .82rem; transition: background .2s; }
    .btn-edit:hover { background: #ffc107; color: #fff; }

    .pagination-bar { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: .35rem; padding: 1rem; background: white; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); margin-bottom: 1rem; }
    .page-btn { border: 1px solid #d0d0d0; background: white; color: #555; padding: .35rem .7rem; border-radius: 4px; cursor: pointer; font-size: .88rem; min-width: 36px; transition: all .15s; }
    .page-btn:hover:not(:disabled) { background: #667eea; color: white; border-color: #667eea; }
    .page-btn.active { background: #667eea; color: white; border-color: #667eea; font-weight: 600; }
    .page-btn:disabled { opacity: .45; cursor: not-allowed; }
    .stats { background: white; padding: 1.25rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 4px rgba(0,0,0,.1); }
    .stats p { margin: 0; color: #555; }

    .loading { display: flex; flex-direction: column; justify-content: center; align-items: center; min-height: 200px; background: white; border-radius: 8px; }

    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000; }
    .modal-panel { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.3); z-index: 1001; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0; color: white; }
    .modal-header h2 { margin: 0; font-size: 1.25rem; }
    .btn-close { background: rgba(255,255,255,.2); border: none; color: white; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; }
    .btn-close:hover { background: rgba(255,255,255,.35); }
    .modal-body { padding: 1.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 500; color: #444; margin-bottom: .35rem; font-size: .9rem; }
    .form-control { width: 100%; padding: .6rem .85rem; border: 1px solid #d0d0d0; border-radius: 5px; font-size: .9rem; box-sizing: border-box; transition: border-color .2s, box-shadow .2s; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.15); }
    .modal-footer { display: flex; justify-content: flex-end; gap: .75rem; padding-top: 1rem; border-top: 1px solid #eee; margin-top: .5rem; }

    @@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .page-header { flex-direction: column; gap: 1rem; } }
</style>
